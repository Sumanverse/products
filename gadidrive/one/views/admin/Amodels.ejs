            </main>
            <%- include('../partials/footer') %>
                <script>
                    document.addEventListener('DOMContentLoaded', function () {
                        // Engine Type Based Field Visibility
                        function updateEngineBasedFields() {
                            const engineType = document.getElementById('engine-type').value;
                            const batteryField = document.getElementById('battery-capacity-field');
                            const iceFields = document.getElementById('ice-fields');

                            // These fields are now removed, so hide them
                            if (batteryField) batteryField.style.display = 'none';
                            if (iceFields) iceFields.style.display = 'none';
                        }

                        // Initialize engine type fields
                        updateEngineBasedFields();
                        const engineTypeSelect = document.getElementById('engine-type');
                        if (engineTypeSelect) {
                            engineTypeSelect.addEventListener('change', updateEngineBasedFields);
                        }

                        // ========== COUNTRY SELECTOR AND DYNAMIC LOADING ==========
                        const countrySelector = document.getElementById('country');
                        const vehicleTypeSelector = document.getElementById('vehicle-type');
                        const categorySelector = document.getElementById('category');
                        const brandSelector = document.getElementById('brand');

                        if (countrySelector) {
                            countrySelector.addEventListener('change', async function () {
                                const selectedOption = this.options[this.selectedIndex];
                                const countryId = selectedOption.getAttribute('data-id');

                                if (countryId) {
                                    // Reset and disable dependent selects
                                    vehicleTypeSelector.disabled = true;
                                    categorySelector.disabled = true;
                                    brandSelector.disabled = true;

                                    vehicleTypeSelector.innerHTML = '<option value="" disabled selected>Loading vehicle types...</option>';
                                    categorySelector.innerHTML = '<option value="" disabled selected>Select Category</option>';
                                    brandSelector.innerHTML = '<option value="" disabled selected>Select Brand</option>';

                                    try {
                                        // Fetch vehicle types for this country
                                        const response = await fetch(`/admin/model/vehicle-types/${countryId}`);
                                        if (!response.ok) throw new Error('Failed to load vehicle types');

                                        const vehicleTypes = await response.json();

                                        // Populate vehicle types
                                        vehicleTypeSelector.innerHTML = '<option value="" disabled selected>Select Vehicle Type</option>';
                                        vehicleTypes.forEach(vt => {
                                            const option = document.createElement('option');
                                            option.value = vt.vehicle_type_name;
                                            option.textContent = vt.vehicle_type_name;
                                            option.setAttribute('data-id', vt.vehicle_type_id);
                                            vehicleTypeSelector.appendChild(option);
                                        });

                                        vehicleTypeSelector.disabled = false;

                    // If editing existing model, try to set the values
                    <% if (model) { %>
                                            setTimeout(() => {
                                                const currentVehicleType = '<%= model.vehicle_type_name %>';
                                                for (let i = 0; i < vehicleTypeSelector.options.length; i++) {
                                                    if (vehicleTypeSelector.options[i].value === currentVehicleType) {
                                                        vehicleTypeSelector.value = currentVehicleType;
                                                        vehicleTypeSelector.dispatchEvent(new Event('change'));
                                                        break;
                                                    }
                                                }
                                            }, 100);
                    <% } %>
                    
                } catch (error) {
                                        console.error('Error loading vehicle types:', error);
                                        vehicleTypeSelector.innerHTML = '<option value="" disabled selected>Error loading vehicle types</option>';
                                        vehicleTypeSelector.disabled = false;
                                    }
                                } else {
                                    vehicleTypeSelector.disabled = true;
                                    categorySelector.disabled = true;
                                    brandSelector.disabled = true;
                                    vehicleTypeSelector.innerHTML = '<option value="" disabled selected>Select Vehicle Type</option>';
                                    categorySelector.innerHTML = '<option value="" disabled selected>Select Category</option>';
                                    brandSelector.innerHTML = '<option value="" disabled selected>Select Brand</option>';
                                }
                            });
                        }

                        // Category and Brand Population based on Vehicle Type
                        if (vehicleTypeSelector) {
                            vehicleTypeSelector.addEventListener('change', async function () {
                                const selectedOption = this.options[this.selectedIndex];
                                const vehicleTypeId = selectedOption.getAttribute('data-id');
                                const countryId = countrySelector ? countrySelector.options[countrySelector.selectedIndex]?.getAttribute('data-id') : null;

                                if (vehicleTypeId) {
                                    categorySelector.disabled = true;
                                    brandSelector.disabled = true;
                                    categorySelector.innerHTML = '<option value="" disabled selected>Loading categories...</option>';
                                    brandSelector.innerHTML = '<option value="" disabled selected>Loading brands...</option>';

                                    try {
                                        const response = await fetch(`/admin/model/filter-data?vehicleTypeId=${vehicleTypeId}&countryId=${countryId || ''}`);
                                        if (!response.ok) throw new Error('Network response was not ok');

                                        const data = await response.json();

                                        // Populate categories
                                        categorySelector.innerHTML = '<option value="" disabled>Select Category</option>';
                                        data.categories.forEach(cat => {
                                            const option = document.createElement('option');
                                            option.value = cat.name;
                                            option.textContent = cat.name;
                                            option.setAttribute('data-id', cat.category_id);
                                            categorySelector.appendChild(option);
                                        });

                                        // Populate brands
                                        brandSelector.innerHTML = '<option value="" disabled>Select Brand</option>';
                                        data.brands.forEach(brand => {
                                            const option = document.createElement('option');
                                            option.value = brand.name;
                                            option.textContent = brand.name;
                                            option.setAttribute('data-id', brand.brand_id);
                                            brandSelector.appendChild(option);
                                        });

                                        categorySelector.disabled = false;
                                        brandSelector.disabled = false;

                    // If editing existing model, try to set the values
                    <% if (model) { %>
                                            setTimeout(() => {
                                                const currentCategory = '<%= model.category_name %>';
                                                const currentBrand = '<%= model.brand_name %>';

                                                // Set category
                                                for (let i = 0; i < categorySelector.options.length; i++) {
                                                    if (categorySelector.options[i].value === currentCategory) {
                                                        categorySelector.value = currentCategory;
                                                        break;
                                                    }
                                                }

                                                // Set brand
                                                for (let i = 0; i < brandSelector.options.length; i++) {
                                                    if (brandSelector.options[i].value === currentBrand) {
                                                        brandSelector.value = currentBrand;
                                                        break;
                                                    }
                                                }
                                            }, 100);
                    <% } %>

                } catch (error) {
                                        console.error('Error loading categories and brands:', error);
                                        categorySelector.innerHTML = '<option value="" disabled selected>Error loading categories</option>';
                                        brandSelector.innerHTML = '<option value="" disabled selected>Error loading brands</option>';
                                    }
                                } else {
                                    categorySelector.disabled = true;
                                    brandSelector.disabled = true;
                                    categorySelector.innerHTML = '<option value="" disabled selected>Select Category</option>';
                                    brandSelector.innerHTML = '<option value="" disabled selected>Select Brand</option>';
                                }
                            });
                        }

    // Initialize for edit mode
    <% if (model) { %>
                            setTimeout(() => {
                                if (countrySelector) {
                                    const currentCountry = '<%= model.country_name %>';
                                    for (let i = 0; i < countrySelector.options.length; i++) {
                                        if (countrySelector.options[i].value === currentCountry) {
                                            countrySelector.value = currentCountry;
                                            countrySelector.dispatchEvent(new Event('change'));
                                            break;
                                        }
                                    }
                                }
                            }, 200);
    <% } %>

    // Published Models Filtering
    const publishedCountrySelector = document.getElementById('published-country-selector');
                        const publishedVehicleTypeSelector = document.getElementById('published-vehicle-type-selector');
                        const publishedBrandSelector = document.getElementById('published-brand-selector');
                        const modelBoxes = document.getElementById('published-model-boxes');
                        const clearFiltersBtn = document.getElementById('clear-filters');

                        // Hide clear filter button initially
                        if (clearFiltersBtn) clearFiltersBtn.style.display = 'none';

                        if (publishedCountrySelector) {
                            publishedCountrySelector.addEventListener('change', async function () {
                                const countryId = this.value;

                                if (countryId) {
                                    if (clearFiltersBtn) clearFiltersBtn.style.display = 'block';
                                    if (publishedVehicleTypeSelector) {
                                        publishedVehicleTypeSelector.disabled = true;
                                        publishedVehicleTypeSelector.innerHTML = '<option value="" disabled selected>Loading vehicle types...</option>';
                                    }
                                    if (publishedBrandSelector) {
                                        publishedBrandSelector.disabled = true;
                                        publishedBrandSelector.innerHTML = '<option value="" disabled selected>Select Brand</option>';
                                    }

                                    try {
                                        const response = await fetch(`/admin/model/vehicle-types/${countryId}`);
                                        if (!response.ok) throw new Error('Network response was not ok');

                                        const vehicleTypes = await response.json();

                                        if (publishedVehicleTypeSelector) {
                                            publishedVehicleTypeSelector.innerHTML = '<option value="" disabled selected>Select Vehicle Type</option>';
                                            vehicleTypes.forEach(vt => {
                                                const option = document.createElement('option');
                                                option.value = vt.vehicle_type_id;
                                                option.textContent = vt.vehicle_type_name;
                                                publishedVehicleTypeSelector.appendChild(option);
                                            });

                                            publishedVehicleTypeSelector.disabled = false;
                                        }

                                        if (modelBoxes) {
                                            modelBoxes.innerHTML = '<div class="text-gray-400 text-center py-8 col-span-full">Select a vehicle type to view brands</div>';
                                        }
                                    } catch (error) {
                                        console.error('Error loading vehicle types:', error);
                                        if (publishedVehicleTypeSelector) {
                                            publishedVehicleTypeSelector.innerHTML = '<option value="" disabled selected>Error loading vehicle types</option>';
                                        }
                                    }
                                } else {
                                    if (clearFiltersBtn) clearFiltersBtn.style.display = 'none';
                                    if (publishedVehicleTypeSelector) {
                                        publishedVehicleTypeSelector.disabled = true;
                                        publishedVehicleTypeSelector.innerHTML = '<option value="" disabled selected>Select Vehicle Type</option>';
                                    }
                                    if (publishedBrandSelector) {
                                        publishedBrandSelector.disabled = true;
                                        publishedBrandSelector.innerHTML = '<option value="" disabled selected>Select Brand</option>';
                                    }
                                    if (modelBoxes) {
                                        modelBoxes.innerHTML = '<div class="text-gray-400 text-center py-8 col-span-full">Select country, vehicle type and brand to view models</div>';
                                    }
                                }
                            });
                        }

                        if (publishedVehicleTypeSelector) {
                            publishedVehicleTypeSelector.addEventListener('change', async function () {
                                const vehicleTypeId = this.value;
                                const countryId = publishedCountrySelector ? publishedCountrySelector.value : '';

                                if (vehicleTypeId) {
                                    if (clearFiltersBtn) clearFiltersBtn.style.display = 'block';
                                    if (publishedBrandSelector) {
                                        publishedBrandSelector.disabled = true;
                                        publishedBrandSelector.innerHTML = '<option value="" disabled selected>Loading brands...</option>';
                                    }

                                    try {
                                        const response = await fetch(`/admin/model/filter-data?vehicleTypeId=${vehicleTypeId}&countryId=${countryId}`);
                                        if (!response.ok) throw new Error('Network response was not ok');

                                        const data = await response.json();

                                        if (publishedBrandSelector) {
                                            publishedBrandSelector.innerHTML = '<option value="" disabled selected>Select Brand</option>';
                                            data.brands.forEach(brand => {
                                                const option = document.createElement('option');
                                                option.value = brand.brand_id;
                                                option.textContent = brand.name;
                                                publishedBrandSelector.appendChild(option);
                                            });

                                            publishedBrandSelector.disabled = false;
                                        }

                                        if (modelBoxes) {
                                            modelBoxes.innerHTML = '<div class="text-gray-400 text-center py-8 col-span-full">Select a brand to view models</div>';
                                        }
                                    } catch (error) {
                                        console.error('Error loading brands:', error);
                                        if (publishedBrandSelector) {
                                            publishedBrandSelector.innerHTML = '<option value="" disabled selected>Error loading brands</option>';
                                        }
                                    }
                                } else {
                                    if (publishedBrandSelector) {
                                        publishedBrandSelector.disabled = true;
                                        publishedBrandSelector.innerHTML = '<option value="" disabled selected>Select Brand</option>';
                                    }
                                }
                            });
                        }

                        if (publishedBrandSelector) {
                            publishedBrandSelector.addEventListener('change', async function () {
                                const vehicleTypeId = publishedVehicleTypeSelector ? publishedVehicleTypeSelector.value : '';
                                const brandId = this.value;

                                if (vehicleTypeId && brandId) {
                                    if (modelBoxes) {
                                        modelBoxes.innerHTML = '<div class="text-gray-400 text-center py-8 col-span-full">Loading models...</div>';

                                        try {
                                            const response = await fetch(`/admin/model/filter-models?vehicleTypeId=${vehicleTypeId}&brandId=${brandId}`);
                                            if (!response.ok) throw new Error('Network response was not ok');

                                            const models = await response.json();

                                            modelBoxes.innerHTML = '';

                                            if (models && models.length > 0) {
                                                models.forEach(model => {
                                                    if (model.html_markup) {
                                                        const tempDiv = document.createElement('div');
                                                        tempDiv.innerHTML = model.html_markup;
                                                        const modelBoxElement = tempDiv.firstElementChild;
                                                        if (modelBoxElement) {
                                                            modelBoxes.appendChild(modelBoxElement);
                                                        }
                                                    } else {
                                                        // Fallback to old simple design if markup is missing
                                                        const div = document.createElement('div');
                                                        div.className = 'bg-gray-800 p-4 rounded-lg shadow-lg';
                                                        div.innerHTML = `
                                        <h3 class="text-lg font-semibold text-white mt-4 truncate">${model.model_name}</h3>
                                        <div class="mt-4 flex space-x-2">
                                            <a href="/admin/model/${model.id}" class="bg-blue-600 text-white px-3 py-1 rounded-lg hover:bg-blue-700 transition text-sm">Edit</a>
                                        </div>
                                    `;
                                                        modelBoxes.appendChild(div);
                                                    }
                                                });
                                            } else {
                                                modelBoxes.innerHTML = '<div class="text-gray-400 text-center py-8 col-span-full">No models found for selected filters.</div>';
                                            }
                                        } catch (error) {
                                            console.error('Error loading models:', error);
                                            modelBoxes.innerHTML = '<div class="text-red-600 text-center py-8 col-span-full">Error loading models. Please try again.</div>';
                                        }
                                    }
                                }
                            });
                        }

                        if (clearFiltersBtn) {
                            clearFiltersBtn.addEventListener('click', function () {
                                if (publishedVehicleTypeSelector) publishedVehicleTypeSelector.value = '';
                                if (publishedBrandSelector) {
                                    publishedBrandSelector.innerHTML = '<option value="" disabled selected>Select Brand</option>';
                                    publishedBrandSelector.disabled = true;
                                }
                                if (modelBoxes) {
                                    modelBoxes.innerHTML = '<div class="text-gray-400 text-center py-8 col-span-full">Select vehicle type and brand to view models</div>';
                                }

                                // Hide the clear filter button
                                clearFiltersBtn.style.display = 'none';
                            });
                        }

                        // Form submission handling
                        const modelForm = document.getElementById('model-form');
                        const submitBtn = document.getElementById('publish-model-btn');
                        const submitText = document.getElementById('submit-text');

                        if (modelForm) {
                            modelForm.addEventListener('submit', function (e) {
                                // Check required fields
                                const requiredFields = modelForm.querySelectorAll('[required]');
                                let isValid = true;

                                requiredFields.forEach(field => {
                                    if (!field.value.trim()) {
                                        isValid = false;
                                        field.classList.add('border-red-500', 'ring-2', 'ring-red-500');
                                    } else {
                                        field.classList.remove('border-red-500', 'ring-2', 'ring-red-500');
                                    }
                                });

                                if (!isValid) {
                                    e.preventDefault();
                                    alert('Please fill in all required fields marked with *.');
                                    return false;
                                }

                                // Show loading state
                                if (submitBtn) {
                                    submitBtn.disabled = true;
                                    submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
                                    const spinner = submitBtn.querySelector('#submit-spinner');
                                    if (spinner) {
                                        spinner.classList.remove('hidden');
                                    }
                                }

                                return true;
                            });
                        }

                        // Mobile Menu Toggle
                        const mobileMenuButton = document.getElementById('mobile-menu-button');
                        const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
                        const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
                        const closeMobileMenuButton = document.getElementById('close-mobile-menu');

                        if (mobileMenuButton) {
                            mobileMenuButton.addEventListener('click', (e) => {
                                e.preventDefault();
                                mobileMenuOverlay.classList.toggle('mobile-menu-open');
                                mobileMenuBackdrop.classList.toggle('active');
                            });
                        }

                        if (closeMobileMenuButton) {
                            closeMobileMenuButton.addEventListener('click', (e) => {
                                e.preventDefault();
                                mobileMenuOverlay.classList.remove('mobile-menu-open');
                                mobileMenuBackdrop.classList.remove('active');
                            });
                        }

                        if (mobileMenuBackdrop) {
                            mobileMenuBackdrop.addEventListener('click', (e) => {
                                e.preventDefault();
                                mobileMenuOverlay.classList.remove('mobile-menu-open');
                                mobileMenuBackdrop.classList.remove('active');
                            });
                        }

                        // ========== DYNAMIC FORM ELEMENTS ==========

                        // Global counters
                        let exteriorColorCount = <%= model && details && details.exteriorColors ? details.exteriorColors.length : 1 %>;
                        let interiorColorCount = <%= model && details && details.interiorColors ? details.interiorColors.length : 1 %>;
                        let variantCount = <%= model && details && details.variants ? details.variants.length : 1 %>;
                        let faqCount = <%= model && details && details.faqs && details.faqs.length > 0 ? details.faqs.length : 1 %>;
                        let siteCount = <%= model && details && details.availableSites ? details.availableSites.length : 1 %>;
                        let contentCount = <%= model && details && details.aboutContents ? details.aboutContents.length : 0 %>;
                        let keyspecCount = <%= model && details && details.keyspecs ? details.keyspecs.length : 1 %>;
                        let specCount = <%= model && details && details.specifications ? details.specifications.length : 1 %>;
                        let hiddenTitleCount = <%= model && details && details.hiddenTitles ? details.hiddenTitles.length : 1 %>;

                        // ========== KEY SPECS DYNAMIC FORM ==========
                        const addKeySpecBtn = document.getElementById('add-keyspec');
                        const keyspecsContainer = document.getElementById('keyspecs');

                        if (addKeySpecBtn && keyspecsContainer) {
                            addKeySpecBtn.addEventListener('click', () => {
                                const div = document.createElement('div');
                                div.className = 'keyspec-group flex space-x-4 mb-4 relative';
                                div.innerHTML = `
                <div class="w-1/2">
                    <label class="block text-sm font-medium text-gray-300 mb-1">Key Spec Name</label>
                    <input type="text" name="keyspecName${keyspecCount + 1}" 
                           class="keyspec-name w-full px-4 py-2 bg-gray-700 border border-red-600 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 text-white" 
                           placeholder="Enter key spec (e.g., Torque, Power)">
                </div>
                <div class="w-1/2">
                    <label class="block text-sm font-medium text-gray-300 mb-1">Key Spec Data</label>
                    <input type="text" name="keyspecData${keyspecCount + 1}" 
                           class="keyspec-data w-full px-4 py-2 bg-gray-700 border border-red-600 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 text-white" 
                           placeholder="Enter spec data (e.g., 115nm, 150bhp)">
                </div>
                <button type="button" class="delete-keyspec-btn absolute top-2 right-2 text-red-600 hover:text-red-700" title="Delete Key Spec">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            `;
                                keyspecsContainer.appendChild(div);
                                keyspecCount++;

                                // Add delete listener
                                addDeleteListener(div, '.delete-keyspec-btn', keyspecsContainer);
                            });
                        }

                        // Initialize delete listeners for existing keyspecs
                        if (keyspecsContainer) {
                            document.querySelectorAll('.keyspec-group').forEach(group => {
                                addDeleteListener(group, '.delete-keyspec-btn', keyspecsContainer);
                            });
                        }

                        // Get correct color group index
                        function getColorGroupIndex(group) {
                            const isExterior = group.classList.contains('exterior-color-group');
                            const container = isExterior ? document.getElementById('exterior-colors') : document.getElementById('interior-colors');
                            if (!container) return 1;
                            const groups = Array.from(container.querySelectorAll(isExterior ? '.exterior-color-group' : '.interior-color-group'));
                            return groups.indexOf(group) + 1;
                        }

                        // Delete listener for all dynamic elements
                        function addDeleteListener(element, buttonSelector, parent) {
                            const deleteBtn = element.querySelector(buttonSelector);
                            if (deleteBtn) {
                                deleteBtn.addEventListener('click', () => {
                                    const groups = parent.children;
                                    if (groups.length > 1) {
                                        element.remove();
                                        // Update all group indices after deletion
                                        updateAllGroupIndices();
                                    } else {
                                        alert('At least one item is required.');
                                    }
                                });
                            }
                        }

                        // Function to update all group indices
                        function updateAllGroupIndices() {
                            // Update keyspec indices
                            const keyspecGroups = document.querySelectorAll('#keyspecs .keyspec-group');
                            keyspecGroups.forEach((group, index) => {
                                const nameInput = group.querySelector('.keyspec-name');
                                const dataInput = group.querySelector('.keyspec-data');
                                if (nameInput) nameInput.name = `keyspecName${index + 1}`;
                                if (dataInput) dataInput.name = `keyspecData${index + 1}`;
                            });
                            keyspecCount = keyspecGroups.length;

                            // Update variant indices
                            const variantGroups = document.querySelectorAll('#variants .variant-group');
                            variantGroups.forEach((group, index) => {
                                const nameInput = group.querySelector('.variant-name');
                                const priceInput = group.querySelector('.variant-price');
                                if (nameInput) nameInput.name = `variantName${index + 1}`;
                                if (priceInput) priceInput.name = `variantPrice${index + 1}`;
                            });
                            variantCount = variantGroups.length;

                            // Update faq indices
                            const faqGroups = document.querySelectorAll('#faqs-container .faq-group');
                            faqGroups.forEach((group, index) => {
                                const questionInput = group.querySelector('.faq-question');
                                const answerInput = group.querySelector('.faq-answer');
                                if (questionInput) questionInput.name = `faqQuestion${index + 1}`;
                                if (answerInput) answerInput.name = `faqAnswer${index + 1}`;
                            });
                            faqCount = faqGroups.length;

                            // Update site indices
                            const siteGroups = document.querySelectorAll('#available-sites .site-group');
                            siteGroups.forEach((group, index) => {
                                const nameInput = group.querySelector('.site-name');
                                const linkInput = group.querySelector('.site-link');
                                if (nameInput) nameInput.name = `siteName${index + 1}`;
                                if (linkInput) linkInput.name = `siteLink${index + 1}`;
                            });
                            siteCount = siteGroups.length;

                            // Update hidden title indices
                            const hiddenTitleGroups = document.querySelectorAll('#hidden-titles .hidden-title-group');
                            hiddenTitleGroups.forEach((group, index) => {
                                const label = group.querySelector('label');
                                const input = group.querySelector('input');
                                if (label) label.textContent = `Hidden Title ${index + 1}`;
                                if (input) input.name = `hiddenTitle${index + 1}`;
                            });
                            hiddenTitleCount = hiddenTitleGroups.length;

                            // Update exterior color indices
                            const exteriorGroups = document.querySelectorAll('#exterior-colors .exterior-color-group');
                            exteriorGroups.forEach((group, index) => {
                                const colorIndex = index + 1;
                                const mainImgInput = group.querySelector('.color-image');
                                const nameInput = group.querySelector('.color-name');
                                if (mainImgInput) mainImgInput.name = `exteriorColorImage${colorIndex}`;
                                if (nameInput) nameInput.name = `exteriorColorName${colorIndex}`;

                            });
                            exteriorColorCount = exteriorGroups.length;

                            // Update interior color indices
                            const interiorGroups = document.querySelectorAll('#interior-colors .interior-color-group');
                            interiorGroups.forEach((group, index) => {
                                const colorIndex = index + 1;
                                const mainImgInput = group.querySelector('.color-image');
                                const nameInput = group.querySelector('.color-name');
                                if (mainImgInput) mainImgInput.name = `interiorColorImage${colorIndex}`;
                                if (nameInput) nameInput.name = `interiorColorName${colorIndex}`;

                            });
                            interiorColorCount = interiorGroups.length;

                            // Update about content indices
                            const aboutGroups = document.querySelectorAll('#content-area > div');
                            aboutGroups.forEach((group, index) => {
                                const cIdx = index + 1;
                                const typeInput = group.querySelector('input[name^="aboutContentType"]');
                                const contentInput = group.querySelector('textarea, input[type="text"], input[type="file"]');
                                const sourceInput = group.querySelector('input[name^="aboutSource"]');

                                if (typeInput) typeInput.name = `aboutContentType${cIdx}`;
                                if (contentInput) {
                                    if (contentInput.tagName === 'TEXTAREA') contentInput.name = `aboutContent${cIdx}`;
                                    else if (contentInput.type === 'file') contentInput.name = `aboutPhoto${cIdx}`;
                                    else contentInput.name = `aboutContent${cIdx}`;
                                }
                                if (sourceInput) sourceInput.name = `aboutSource${cIdx}`;
                            });
                            contentCount = aboutGroups.length;

                            // Update specification indices (Nested)
                            const specGroups = document.querySelectorAll('#specifications .spec-group');
                            specGroups.forEach((group, sIndex) => {
                                const sIdx = sIndex + 1;
                                const titleInput = group.querySelector('.spec-title');
                                if (titleInput) titleInput.name = `specTitle${sIdx}`;

                                // Update spec list groups within this spec
                                const listGroups = group.querySelectorAll('.spec-list-group');
                                listGroups.forEach((lGroup, lIndex) => {
                                    const lIdx = lIndex + 1;
                                    const listTitleInput = lGroup.querySelector('.spec-list-title');
                                    if (listTitleInput) listTitleInput.name = `specListTitle${sIdx}_${lIdx}`;

                                    // Update contents within this list
                                    const contentGroups = lGroup.querySelectorAll('.spec-content-area > div > div');
                                    contentGroups.forEach((cGroup, cIndex) => {
                                        const cIdx = cIndex + 1;
                                        const typeInput = cGroup.querySelector('input[name^="specContentType"]');
                                        const contentInput = cGroup.querySelector('textarea, input[type="text"], input[type="file"]');
                                        const sourceInput = cGroup.querySelector('input[name^="specSource"]');

                                        if (typeInput) typeInput.name = `specContentType${sIdx}_${lIdx}_${cIdx}`;
                                        if (contentInput) {
                                            if (contentInput.tagName === 'TEXTAREA') contentInput.name = `specContent${sIdx}_${lIdx}_${cIdx}`;
                                            else if (contentInput.type === 'file') contentInput.name = `specPhoto${sIdx}_${lIdx}_${cIdx}`;
                                            else contentInput.name = `specContent${sIdx}_${lIdx}_${cIdx}`;
                                        }
                                        if (sourceInput) sourceInput.name = `specSource${sIdx}_${lIdx}_${cIdx}`;
                                    });
                                });
                            });
                            specCount = specGroups.length;
                        }

                        // ========== EXTERIOR COLORS ==========
                        const addExteriorColorBtn = document.getElementById('add-exterior-color');
                        if (addExteriorColorBtn) {
                            addExteriorColorBtn.addEventListener('click', () => {
                                const exteriorColors = document.getElementById('exterior-colors');
                                if (!exteriorColors) return;

                                const div = document.createElement('div');
                                div.className = 'exterior-color-group mb-4 relative';
                                div.innerHTML = `
                <div class="flex space-x-4 mb-2">
                    <div class="w-1/2">
                        <label class="block text-sm font-medium text-gray-300 mb-1">Color Image</label>
                        <input type="file" accept="image/*" name="exteriorColorImage${exteriorColorCount + 1}" class="color-image w-full text-white bg-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-red-600 file:text-white hover:file:bg-red-700">
                    </div>
                    <div class="w-1/2">
                        <label class="block text-sm font-medium text-gray-300 mb-1">Color Name</label>
                        <input type="text" name="exteriorColorName${exteriorColorCount + 1}" class="color-name w-full px-4 py-2 bg-gray-700 border border-red-600 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 text-white" placeholder="Enter color name (e.g., Midnight Black)">
                    </div>

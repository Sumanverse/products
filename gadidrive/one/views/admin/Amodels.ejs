                </button>
                <button type="button" class="spec-link-icon icon-button bg-gray-700 p-2 rounded-full hover:bg-red-600 transition" title="Add Link">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
                </button>
            </div>
            
            <div class="spec-content-area relative"></div>
            
            <button type="button" class="delete-spec-list-btn absolute top-0 right-0 text-red-600 hover:text-red-700" title="Delete Spec List">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        `;

                            specLists.appendChild(listDiv);

                            // Add event listeners for the new list
                            addSpecListListenersToNewList(listDiv, specIndex, listCount);

                            // Add delete listener for the new spec list
                            addDeleteListener(listDiv, '.delete-spec-list-btn', specLists);
                        }

                        // Function to get specification index
                        function getSpecIndex(specGroup) {
                            const allSpecGroups = document.querySelectorAll('.spec-group');
                            const index = Array.from(allSpecGroups).indexOf(specGroup) + 1;
                            return index;
                        }

                        // Function to add listeners to new spec list
                        function addSpecListListenersToNewList(listDiv, specIndex, listIndex) {
                            // Article icon
                            const articleIcon = listDiv.querySelector('.spec-article-icon');
                            if (articleIcon) {
                                articleIcon.addEventListener('click', () => {
                                    addSpecContent(listDiv, specIndex, listIndex, 'article');
                                });
                            }

                            // Photo icon
                            const photoIcon = listDiv.querySelector('.spec-photo-icon');
                            if (photoIcon) {
                                photoIcon.addEventListener('click', () => {
                                    addSpecContent(listDiv, specIndex, listIndex, 'photo');
                                });
                            }

                            // Link icon
                            const linkIcon = listDiv.querySelector('.spec-link-icon');
                            if (linkIcon) {
                                linkIcon.addEventListener('click', () => {
                                    addSpecContent(listDiv, specIndex, listIndex, 'link');
                                });
                            }
                        }

                        // Initialize existing specification groups
                        document.querySelectorAll('.spec-group').forEach(specGroup => {
                            const specIndex = getSpecIndex(specGroup);

                            // Add event listeners for existing spec lists
                            specGroup.querySelectorAll('.spec-list-group').forEach((listDiv, listIndex) => {
                                addSpecListListenersToNewList(listDiv, specIndex, listIndex + 1);

                                // Add delete listener for existing spec lists
                                const specLists = specGroup.querySelector('.spec-lists');
                                if (specLists) {
                                    addDeleteListener(listDiv, '.delete-spec-list-btn', specLists);
                                }
                            });

                            // Add spec list button functionality
                            const addSpecListBtn = specGroup.querySelector('.add-spec-list');
                            if (addSpecListBtn) {
                                addSpecListBtn.addEventListener('click', () => {
                                    addNewSpecList(specGroup);
                                });
                            }

                            // Add delete listener for specification
                            const specifications = document.getElementById('specifications');
                            if (specifications) {
                                addDeleteListener(specGroup, '.delete-spec-btn', specifications);
                            }
                        });


                        // Initialize delete listeners for existing elements
                        const exteriorColorsContainer = document.getElementById('exterior-colors');
                        if (exteriorColorsContainer) {
                            document.querySelectorAll('.exterior-color-group').forEach(group => addDeleteListener(group, '.delete-color-btn', exteriorColorsContainer));
                        }

                        const interiorColorsContainer = document.getElementById('interior-colors');
                        if (interiorColorsContainer) {
                            document.querySelectorAll('.interior-color-group').forEach(group => addDeleteListener(group, '.delete-color-btn', interiorColorsContainer));
                        }

                        const variantsContainer = document.getElementById('variants');
                        if (variantsContainer) {
                            document.querySelectorAll('.variant-group').forEach(group => addDeleteListener(group, '.delete-variant-btn', variantsContainer));
                        }

                        const sitesContainer = document.getElementById('available-sites');
                        if (sitesContainer) {
                            document.querySelectorAll('.site-group').forEach(group => addDeleteListener(group, '.delete-site-btn', sitesContainer));
                        }

                        if (contentArea) {
                            document.querySelectorAll('#content-area > div').forEach(group => addDeleteListener(group, '.remove-content-btn', contentArea));
                        }

                        // Search Functionality
                        const searchButton = document.getElementById('search-button');
                        if (searchButton) {
                            searchButton.addEventListener('click', () => {
                                const query = document.getElementById('search-input').value;
                                if (query) {
                                    alert('Search for: ' + query);
                                } else {
                                    alert('Please enter a search query.');
                                }
                            });
                        }

                        // Highlight Active Nav Link
                        const navLinks = document.querySelectorAll('#desktop-nav-links a, .mobile-nav-link');
                        const currentPath = window.location.pathname;
                        navLinks.forEach(link => {
                            if (link.getAttribute('href') === currentPath) {
                                link.classList.add('bg-red-600', 'text-white');
                                link.classList.remove('hover:bg-red-600');
                            }
                        });
                    });
                </script>

    </body>

    </html>
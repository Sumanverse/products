<%- include('partials/head', {
    title: title || `Search: ${query} - GadiDrive`,
    description: description || `Search results for "${query}"`,
    keywords: keywords || `search, ${query}, vehicles, brands, news`,
    url: currentUrl,
    path: path,
    country: country
}) %>

<style>
    body {
        background-color: #000000;
        font-family: 'Poppins', sans-serif;
    }
    
    .wheel { 
        animation: spin 12s linear infinite; 
        filter: drop-shadow(0 0 15px rgba(220,38,38,0.5));
    }
    .wheel:hover { 
        animation: spin 0.5s linear infinite; 
        filter: drop-shadow(0 0 40px rgba(220,38,38,1));
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    
    .smoke {
        position: absolute; 
        bottom: -100px; 
        left: 50%; 
        width: 400px; 
        height: 160px;
        background: linear-gradient(to top, rgba(255,255,255,0.3), transparent);
        filter: blur(30px); 
        border-radius: 50%; 
        opacity: 0;
        transform: translateX(-50%); 
        pointer-events: none;
        transition: opacity 1.8s ease-out, bottom 1.8s ease-out; 
        z-index: 1;
    }
    .smoke.active { 
        opacity: 0.8; 
        bottom: -30px; 
    }
    
    .search-result-card {
        background: #111111;
        border: 1px solid #374151;
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    
    .search-result-card:hover {
        border-color: #DC2626;
        transform: translateY(-5px);
    }
    
    .type-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.70rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        border: 1px solid;
    }
    
    .type-badge.VehicleType { background: #059669; border-color: #10b981; }
    .type-badge.PriceList { background: #DC2626; border-color: #ef4444; }
    .type-badge.Brand { background: #2563eb; border-color: #3b82f6; }
    .type-badge.Category { background: #7c3aed; border-color: #8b5cf6; }
    .type-badge.Model { background: #6366f1; border-color: #818cf8; }
    .type-badge.News { background: #d97706; border-color: #f59e0b; }
    .type-badge.Author { background: #6b7280; border-color: #9ca3af; }

    /* Match Category/Brand Box Design */
    .search-card {
        background: #0d0d0d;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 1.25rem;
        transition: all 0.5s ease-out;
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        position: relative;
    }
    
    .search-card:hover {
        border-color: rgba(220, 38, 38, 0.5);
        box-shadow: 0 20px 50px -15px rgba(220, 38, 38, 0.3);
        transform: translateY(-5px);
    }

    .search-image-container {
        position: relative;
        width: 100%;
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(to bottom, rgba(255,255,255,0.03) 0%, transparent 100%);
        padding: 1.5rem;
    }

    .country-badge {
        display: inline-block;
        background: rgba(220, 38, 38, 0.15);
        color: #DC2626;
        padding: 0.35rem 1.4rem;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 500;
        border: 1px solid rgba(220, 38, 38, 0.3);
        letter-spacing: 0.02em;
        margin-top: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .search-image-container img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transition: all 0.7s ease-in-out;
    }

    .search-card:hover .search-image-container img {
        transform: scale(1.1) rotate(-2deg);
    }
</style>



<body class="min-h-screen flex flex-col bg-black text-white font-['Poppins']">

<%- include('partials/navbar', { 
    currentPage: 'search',
    country: country,
    allVehicleTypes: []
}) %>

<main class="flex-grow container mx-auto px-4 py-12">

    <% if (results.length > 0) { %>
        <!-- Results Found -->
        <div class="mb-16 text-center">
            <h1 class="text-3xl md:text-5xl font-semibold mb-4 tracking-tight text-white">
                Results for <span class="text-red-600 font-medium">"<%= query %>"</span>
            </h1>
            <div class="country-badge"><%= results.length %> items found in <%= countryDisplay %></div>
        </div>

        <!-- Results Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 max-w-7xl mx-auto">
            <% results.forEach(item => { %>
                <a href="<%= item.url %>" class="group block h-full">
                    <div class="search-card">
                        <div class="search-image-container">
                            <% if (item.image && item.image.trim()) { %>
                                <img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy">
                            <% } else { %>
                                <span class="text-5xl font-medium text-white/5 select-none"><%= item.title.charAt(0) %></span>
                            <% } %>
                            <span class="type-badge <%= item.type.replace(' ', '') %>">
                                <%= item.type %>
                            </span>
                            <div class="absolute bottom-0 inset-x-0 h-1/3 bg-gradient-to-t from-red-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                        </div>

                        <div class="px-2 pb-2 md:px-3 md:pb-3 mt-auto">
                            <div class="bg-[#151515] border border-white/5 rounded-xl p-2.5 md:p-3.5 flex items-center justify-between transition-all duration-300 group-hover:bg-[#1a0505] group-hover:border-red-600/30">
                                <div class="flex flex-col overflow-hidden">
                                    <h3 class="text-[14px] sm:text-[15px] md:text-base font-medium text-white tracking-wide leading-none transition-colors truncate group-hover:text-red-500 duration-300">
                                        <%= item.title %>
                                    </h3>
                                </div>
                                <div class="bg-white/5 px-2 py-1 md:px-3 md:py-1.5 rounded-lg border border-white/5 transition-all duration-300 group-hover:bg-red-600 group-hover:border-red-600 group-hover:shadow-[0_0_15px_rgba(220,38,38,0.4)] flex-shrink-0">
                                    <span class="text-[9px] md:text-[10px] font-medium tracking-widest text-white flex items-center gap-1 md:gap-1.5">
                                        <span class="hidden xs:block">EXPLORE</span> 
                                        <svg class="w-2.5 h-2.5 md:w-3 md:h-3 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/>
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="absolute bottom-0 left-0 h-[2px] md:h-[3px] w-0 bg-red-600 transition-all duration-700 group-hover:w-full"></div>
                    </div>
                </a>
            <% }) %>
        </div>

    <% } else { %>
        <!-- No Results Found - Animated -->
        <div class="flex flex-col items-center justify-center min-h-[60vh]">
            <div class="flex items-center justify-center gap-4 md:gap-6">
                <span class="text-6xl md:text-8xl font-semibold text-gray-300 select-none -mr-6 md:-mr-8">N</span>

                <div class="relative">
                    <svg id="wheel" width="120" height="120" viewBox="0 0 24 24" class="wheel" fill="none" stroke="#DC2626" stroke-width="1.5">
                        <circle cx="12" cy="12" r="10" stroke="#666" stroke-width="2"/>
                        <circle cx="12" cy="12" r="7" stroke="#222" stroke-width="1.5" fill="#111"/>
                        <circle cx="12" cy="12" r="3.2" fill="#DC2626"/>
                        <path d="M12 2v4M12 18v4M2 12h4M18 12h4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" 
                              stroke="#DC2626" stroke-width="1.5"/>
                    </svg>
                    <div id="smoke" class="smoke"></div>
                </div>

                <span class="text-6xl md:text-8xl font-semibold text-gray-300 select-none -ml-6 md:-ml-8">T</span>
            </div>

            <div class="text-5xl md:text-6xl font-semibold text-red-600 mt-6 tracking-wide">
                FOUND
            </div>

            <div class="mt-12 text-center">
                <h2 class="text-2xl md:text-3xl font-medium text-white">
                    Results for <span class="text-red-600 font-medium">"<%= query %>"</span>
                </h2>
                <p class="text-xl text-gray-400 mt-2">0 items found in <%= countryDisplay %></p>
                
                <!-- Suggestions -->
                <div class="mt-8 text-gray-500">
                    <p>Try:</p>
                    <ul class="mt-2 space-y-1">
                        <li>• Checking spelling</li>
                        <li>• Using more general keywords</li>
                        <li>• Browsing our <a href="<%= countryPrefix %>/car/brands" class="text-red-500 hover:underline">brands</a> or <a href="<%= countryPrefix %>/car/category" class="text-red-500 hover:underline">categories</a></li>
                    </ul>
                </div>
            </div>
        </div>
    <% } %>

</main>

<%- include('partials/footer', { 
    country: country,
    allCountries: allCountries,
    allVehicleTypes: []
}) %>

<!-- Smoke effect only when no results -->
<% if (results.length === 0) { %>
<script>
    const wheel = document.getElementById('wheel');
    const smoke = document.getElementById('smoke');
    let timer;
    
    wheel.addEventListener('mouseenter', () => {
        timer = setTimeout(() => smoke.classList.add('active'), 2500);
    });
    
    wheel.addEventListener('mouseleave', () => {
        clearTimeout(timer);
        smoke.classList.remove('active');
    });
</script>
<% } %>

</body>
</html>
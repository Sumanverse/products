<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { 
        title: 'About GadiDrive | Global Automotive Information Hub',
        description: 'Learn about GadiDrive, your trusted global source for automotive information. We provide accurate vehicle specifications, comparisons, and latest news for enthusiasts worldwide.',
        keywords: 'About GadiDrive, automotive platform, vehicle enthusiasts, car specifications, global automotive',
        path: '/about',
        country: null
    }) %>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&family=Bebas+Neue&display=swap');

        :root {
            --red: #DC2626;
            --red-dark: #b91c1c;
            --red-glow: rgba(220, 38, 38, 0.18);
            --card-bg: #0f0f0f;
            --card-border: rgba(255,255,255,0.07);
            --text-muted: #9ca3af;
            --text-dim: rgba(255,255,255,0.35);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html { scroll-behavior: smooth; }

        body {
            background: #000;
            color: #fff;
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ── NOISE OVERLAY ── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 0;
            opacity: 0.4;
        }

        /* ── PAGE GLOW ── */
        .page-glow {
            position: fixed;
            top: -300px;
            left: 50%;
            transform: translateX(-50%);
            width: 900px;
            height: 600px;
            background: radial-gradient(ellipse, rgba(220,38,38,0.1) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        /* ── MAIN CONTENT ── */
        .page-wrap {
            position: relative;
            z-index: 1;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* ─────────────────────────────────────
           NAVBAR (kept exactly as original)
        ───────────────────────────────────── */
        .navbar-minimal { padding: 1.5rem 0; }
        .navbar-minimal .logo { text-align: left; }
        .navbar-minimal .logo a {
            font-size: 2rem;
            font-weight: 700;
            text-decoration: none;
            color: #fff;
            font-family: 'Poppins', sans-serif;
        }
        .navbar-minimal .logo span { color: var(--red); }

        /* ─────────────────────────────────────
           HERO
        ───────────────────────────────────── */
        .hero {
            padding: 6rem 0 4rem;
            text-align: center;
            position: relative;
        }

        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(220,38,38,0.1);
            border: 1px solid rgba(220,38,38,0.25);
            border-radius: 100px;
            padding: 6px 18px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--red);
            margin-bottom: 2rem;
            animation: fadeUp 0.6s ease both;
        }

        .hero-eyebrow::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--red);
            animation: pulse 1.8s ease infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.7); }
        }

        .hero-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(5rem, 14vw, 11rem);
            line-height: 0.92;
            letter-spacing: 3px;
            color: #fff;
            margin-bottom: 0.3em;
            animation: fadeUp 0.7s 0.1s ease both;
        }

        .hero-title .accent { color: var(--red); }

        .hero-title .word-about {
            display: block;
            font-size: 0.38em;
            letter-spacing: 0.5em;
            color: var(--text-dim);
            font-family: 'Poppins', sans-serif;
            font-weight: 300;
            text-transform: uppercase;
            margin-bottom: 0.2em;
        }

        .hero-sub {
            font-size: clamp(1rem, 2vw, 1.2rem);
            color: var(--text-muted);
            max-width: 600px;
            margin: 1.5rem auto 0;
            line-height: 1.7;
            font-weight: 300;
            animation: fadeUp 0.8s 0.2s ease both;
        }

        /* ── SCROLL INDICATOR ── */
        .scroll-hint {
            margin-top: 3.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            animation: fadeUp 1s 0.5s ease both;
        }

        .scroll-hint span {
            font-size: 10px;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--text-dim);
            font-weight: 500;
        }

        .scroll-line {
            width: 1px;
            height: 50px;
            background: linear-gradient(180deg, var(--red), transparent);
            animation: scrollDrop 1.6s ease infinite;
        }

        @keyframes scrollDrop {
            0% { transform: scaleY(0); transform-origin: top; }
            50% { transform: scaleY(1); transform-origin: top; }
            51% { transform: scaleY(1); transform-origin: bottom; }
            100% { transform: scaleY(0); transform-origin: bottom; }
        }

        /* ─────────────────────────────────────
           SECTION COMMONS
        ───────────────────────────────────── */
        section { padding: 5rem 0; }

        .section-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--red);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .section-label::before, .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(220,38,38,0.25);
        }

        .section-label.left::before { display: none; }
        .section-label.left::after { flex: 0; width: 40px; }

        .section-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: clamp(2.8rem, 6vw, 4.5rem);
            letter-spacing: 2px;
            color: #fff;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .section-title .accent { color: var(--red); }

        /* ─────────────────────────────────────
           STORY SECTION
        ───────────────────────────────────── */
        .story-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .story-text p {
            color: var(--text-muted);
            line-height: 1.85;
            font-weight: 300;
            font-size: 1.05rem;
        }

        .story-text p + p { margin-top: 1.2rem; }

        .story-text strong { color: #fff; font-weight: 600; }

        .story-visual {
            position: relative;
            height: 360px;
        }

        .story-card-bg {
            position: absolute;
            inset: 0;
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            overflow: hidden;
        }

        .story-card-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse 60% 50% at 30% 40%, rgba(220,38,38,0.12) 0%, transparent 60%),
                radial-gradient(ellipse 40% 60% at 80% 70%, rgba(220,38,38,0.06) 0%, transparent 60%);
        }

        .story-stat-grid {
            position: absolute;
            inset: 0;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1px;
            background: rgba(255,255,255,0.04);
            border-radius: 24px;
            overflow: hidden;
        }

        .story-stat {
            background: var(--card-bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            padding: 1.5rem;
        }

        .story-stat-num {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 3.2rem;
            line-height: 1;
            color: #fff;
        }

        .story-stat-num .stat-accent { color: var(--red); }

        .story-stat-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--text-dim);
            text-align: center;
        }

        /* ─────────────────────────────────────
           MISSION / VISION
        ───────────────────────────────────── */
        .mv-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }

        .mv-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
            transition: border-color 0.3s ease, transform 0.3s ease;
        }

        .mv-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--red), transparent);
        }

        .mv-card:hover {
            border-color: rgba(220,38,38,0.3);
            transform: translateY(-4px);
        }

        .mv-card-icon {
            font-size: 2.5rem;
            margin-bottom: 1.5rem;
            display: block;
        }

        .mv-card h3 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2rem;
            letter-spacing: 2px;
            color: #fff;
            margin-bottom: 1rem;
        }

        .mv-card p {
            color: var(--text-muted);
            line-height: 1.8;
            font-weight: 300;
            font-size: 0.95rem;
        }

        /* ─────────────────────────────────────
           WHAT WE OFFER
        ───────────────────────────────────── */
        .offer-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }

        .offer-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: all 0.35s ease;
            cursor: default;
        }

        .offer-card::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 60% 60% at 50% 110%, rgba(220,38,38,0.12) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.35s ease;
        }

        .offer-card:hover {
            border-color: rgba(220,38,38,0.3);
            transform: translateY(-6px);
        }

        .offer-card:hover::after { opacity: 1; }

        .offer-icon {
            width: 72px;
            height: 72px;
            background: rgba(220,38,38,0.1);
            border: 1px solid rgba(220,38,38,0.2);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 1.5rem;
            transition: all 0.3s ease;
        }

        .offer-card:hover .offer-icon {
            background: rgba(220,38,38,0.2);
            border-color: rgba(220,38,38,0.5);
            transform: scale(1.1) rotate(-3deg);
        }

        .offer-card h3 {
            font-weight: 700;
            font-size: 1.1rem;
            color: #fff;
            margin-bottom: 0.8rem;
        }

        .offer-card p {
            color: var(--text-muted);
            font-size: 0.9rem;
            line-height: 1.7;
            font-weight: 300;
        }

        /* ─────────────────────────────────────
           WHY CHOOSE US
        ───────────────────────────────────── */
        .why-section { background: transparent; }

        .why-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
        }

        .why-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            padding: 2.5rem 1.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: all 0.35s ease;
        }

        .why-card:hover {
            border-color: rgba(220,38,38,0.3);
            transform: translateY(-5px);
            box-shadow: 0 20px 50px rgba(220,38,38,0.08);
        }

        .why-card-num {
            position: absolute;
            top: 1rem;
            right: 1.2rem;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.6rem;
            color: rgba(255,255,255,0.04);
            line-height: 1;
            transition: color 0.3s ease;
        }

        .why-card:hover .why-card-num { color: rgba(220,38,38,0.12); }

        .why-icon-wrap {
            width: 80px;
            height: 80px;
            background: var(--red);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2.2rem;
            box-shadow: 0 8px 24px rgba(220,38,38,0.3);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .why-card:hover .why-icon-wrap {
            transform: scale(1.08) rotate(5deg);
            box-shadow: 0 14px 32px rgba(220,38,38,0.45);
        }

        .why-card h4 {
            font-weight: 700;
            font-size: 1.05rem;
            color: #fff;
            margin-bottom: 0.8rem;
        }

        .why-card p {
            color: var(--text-muted);
            font-size: 0.87rem;
            line-height: 1.7;
            font-weight: 300;
        }

        /* ─────────────────────────────────────
           CONTACT STRIP
        ───────────────────────────────────── */
        .contact-strip {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            padding: 3.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 2rem;
            position: relative;
            overflow: hidden;
        }

        .contact-strip::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 50% 80% at 0% 50%, rgba(220,38,38,0.07) 0%, transparent 60%);
            pointer-events: none;
        }

        .contact-text h2 {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.8rem;
            letter-spacing: 2px;
            color: #fff;
            line-height: 1;
        }

        .contact-text p {
            color: var(--text-muted);
            margin-top: 0.5rem;
            font-size: 0.95rem;
            font-weight: 300;
        }

        .contact-links {
            display: flex;
            gap: 1rem;
            flex-shrink: 0;
        }

        .contact-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0.8rem 1.8rem;
            border-radius: 100px;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            transition: all 0.3s ease;
            letter-spacing: 0.02em;
        }

        .contact-btn.primary {
            background: var(--red);
            color: #fff;
            border: 1px solid var(--red);
        }

        .contact-btn.primary:hover {
            background: var(--red-dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(220,38,38,0.3);
        }

        .contact-btn.secondary {
            background: transparent;
            color: rgba(255,255,255,0.7);
            border: 1px solid rgba(255,255,255,0.12);
        }

        .contact-btn.secondary:hover {
            border-color: rgba(220,38,38,0.4);
            color: #fff;
            transform: translateY(-2px);
        }

        /* ─────────────────────────────────────
           ANIMATIONS
        ───────────────────────────────────── */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }

        .reveal.visible {
            opacity: 1;
            transform: none;
        }

        .reveal-delay-1 { transition-delay: 0.1s; }
        .reveal-delay-2 { transition-delay: 0.2s; }
        .reveal-delay-3 { transition-delay: 0.3s; }
        .reveal-delay-4 { transition-delay: 0.4s; }

        /* ─────────────────────────────────────
           RESPONSIVE
        ───────────────────────────────────── */
        @media (max-width: 1024px) {
            .why-grid { grid-template-columns: repeat(2, 1fr); }
            .story-grid { grid-template-columns: 1fr; gap: 2.5rem; }
            .story-visual { height: 280px; }
        }

        @media (max-width: 768px) {
            section { padding: 3.5rem 0; }
            .container { padding: 0 1.25rem; }
            .hero { padding: 3.5rem 0 2.5rem; }
            .mv-grid { grid-template-columns: 1fr; gap: 1.2rem; }
            .offer-grid { grid-template-columns: 1fr; gap: 1.2rem; }
            .why-grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
            .contact-strip {
                flex-direction: column;
                align-items: flex-start;
                padding: 2.5rem 2rem;
            }
            .contact-links { flex-wrap: wrap; }
            .navbar-minimal .logo { text-align: center; }
        }

        @media (max-width: 480px) {
            .why-grid { grid-template-columns: 1fr; }
            .story-stat-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>
    <div class="page-glow"></div>
    <div class="page-wrap">

        <%- include('partials/navbar-minimal') %>

        <main>

            <!-- ═══ HERO ═══ -->
            <section class="hero">
                <div class="container">
                    <div class="hero-eyebrow">Global Automotive Hub</div>
                    <h1 class="hero-title">
                        <span class="word-about">About</span>
                        Gadi<span class="accent">Drive</span>
                    </h1>
                    <p class="hero-sub">Your gateway to accurate vehicle data, smart comparisons, and the latest automotive news — from anywhere in the world.</p>
                    <div class="scroll-hint">
                        <span>Scroll</span>
                        <div class="scroll-line"></div>
                    </div>
                </div>
            </section>

            <!-- ═══ OUR STORY ═══ -->
            <section id="our-story">
                <div class="container">
                    <div class="story-grid reveal">
                        <div class="story-text">
                            <div class="section-label left">Our Story</div>
                            <h2 class="section-title">Built by<br><span class="accent">Enthusiasts,</span><br>for Enthusiasts</h2>
                            <p style="margin-top:1.5rem;">Founded by a team of passionate car and bike lovers, <strong>GadiDrive</strong> started with one goal — create a clean, fast, and reliable global platform for vehicle information, without confusing ads or outdated data.</p>
                            <p>Today, we're a trusted source for automotive information worldwide, helping thousands of enthusiasts make smarter vehicle choices every single day.</p>
                        </div>
                        <div class="story-visual reveal reveal-delay-2">
                            <div class="story-card-bg"></div>
                            <div class="story-stat-grid">
                                <div class="story-stat">
                                    <div class="story-stat-num">50<span class="stat-accent">+</span></div>
                                    <div class="story-stat-label">Brands Listed</div>
                                </div>
                                <div class="story-stat">
                                    <div class="story-stat-num">100<span class="stat-accent">%</span></div>
                                    <div class="story-stat-label">Free Forever</div>
                                </div>
                                <div class="story-stat">
                                    <div class="story-stat-num">10<span class="stat-accent">+</span></div>
                                    <div class="story-stat-label">Countries</div>
                                </div>
                                <div class="story-stat">
                                    <div class="story-stat-num">24<span class="stat-accent">/7</span></div>
                                    <div class="story-stat-label">Always Available</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ═══ MISSION & VISION ═══ -->
            <section>
                <div class="container">
                    <div class="section-label">Our Purpose</div>
                    <h2 class="section-title" style="margin-bottom:3rem;">Mission &amp; <span class="accent">Vision</span></h2>
                    <div class="mv-grid">
                        <div class="mv-card reveal">
                            <span class="mv-card-icon">🎯</span>
                            <h3>Our Mission</h3>
                            <p>To empower every vehicle enthusiast with accurate, up-to-date information — through detailed specifications, fair comparisons, and the latest industry news from around the world.</p>
                        </div>
                        <div class="mv-card reveal reveal-delay-2" id="vision">
                            <span class="mv-card-icon">👁️</span>
                            <h3>Our Vision</h3>
                            <p>To become the world's most trusted name in automotive information, connecting enthusiasts with the data they need to make confident, informed decisions.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ═══ WHAT WE OFFER ═══ -->
            <section id="services">
                <div class="container">
                    <div class="section-label">What We Offer</div>
                    <h2 class="section-title" style="margin-bottom:3rem;">Our <span class="accent">Services</span></h2>
                    <div class="offer-grid">
                        <div class="offer-card reveal">
                            <div class="offer-icon">🚗</div>
                            <h3>Detailed Specifications</h3>
                            <p>Complete technical details, features, and pricing for vehicle models from multiple countries — always current.</p>
                        </div>
                        <div class="offer-card reveal reveal-delay-2">
                            <div class="offer-icon">⚖️</div>
                            <h3>Easy Comparison</h3>
                            <p>Compare any two vehicles side-by-side with our powerful comparison tool. Specs, price, features — all in one view.</p>
                        </div>
                        <div class="offer-card reveal reveal-delay-3">
                            <div class="offer-icon">📰</div>
                            <h3>Latest News & Updates</h3>
                            <p>New launches, price changes, industry news, and automotive trends from around the world, updated daily.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ═══ WHY CHOOSE US ═══ -->
            <section class="why-section">
                <div class="container">
                    <div class="section-label">Why Us</div>
                    <h2 class="section-title" style="margin-bottom:3rem;">Why Choose <span class="accent">GadiDrive?</span></h2>
                    <div class="why-grid">
                        <div class="why-card reveal">
                            <span class="why-card-num">01</span>
                            <div class="why-icon-wrap">✓</div>
                            <h4>Highly Accurate</h4>
                            <p>We verify every spec to ensure you get the most reliable data from trusted sources.</p>
                        </div>
                        <div class="why-card reveal reveal-delay-1">
                            <span class="why-card-num">02</span>
                            <div class="why-icon-wrap">⚡</div>
                            <h4>Lightning Fast</h4>
                            <p>Optimized for speed on any device, anywhere in the world — zero compromises.</p>
                        </div>
                        <div class="why-card reveal reveal-delay-2">
                            <span class="why-card-num">03</span>
                            <div class="why-icon-wrap">🌍</div>
                            <h4>Global Coverage</h4>
                            <p>Information from multiple countries with local prices, specs, and regional details.</p>
                        </div>
                        <div class="why-card reveal reveal-delay-3">
                            <span class="why-card-num">04</span>
                            <div class="why-icon-wrap">💰</div>
                            <h4>Completely Free</h4>

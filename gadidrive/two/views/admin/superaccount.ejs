        <!-- Toggle Buttons -->
        <div class="flex justify-center space-x-4 mb-6 flex-wrap gap-2">
            <button class="toggle-item bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 transition" onclick="showContent('users')">Users</button>
            <button class="toggle-item bg-gray-800 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition" onclick="showContent('vehicleType')">Vehicle Types</button>
            <button class="toggle-item bg-gray-800 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition" onclick="showContent('countries')">Countries</button>

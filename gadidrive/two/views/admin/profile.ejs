                    <h3 class="text-lg font-semibold mb-2">Socials</h3>
                    <div class="flex justify-center lg:justify-start space-x-4" id="socialLinks">
                        <% 
                        const socials = Array.isArray(user.socialMedia) ? user.socialMedia : [];
                        if (socials.length > 0) {
                            socials.forEach(social => {
                                let iconSvg = '';
                                let platform = '';
                                switch(social.type) {
                                    case 'facebook': iconSvg = '<path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>'; platform = 'Facebook'; break;

<%- include('partials/head', {
    title: '404 - Page Not Found | GadiDrive',
    description: 'The page you are looking for does not exist.',
    path: path || '/',
    country: country || null
}) %>

<style>
    /* Import Poppins Font */
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');
    
    /* Pure Black Background */
    body {
        background-color: #000000;
        min-height: 100vh;
        font-family: 'Poppins', sans-serif;
        color: white;
        margin: 0;
        padding: 0;
    }
    
    /* Navbar - Left Aligned with Original Style */
    .navbar-minimal {
        padding: 1.5rem 0;
    }
    
    .navbar-minimal .logo {
        text-align: left;
    }
    
    .navbar-minimal .logo a {
        font-size: 2rem;
        font-weight: 700;
        text-decoration: none;
        color: #ffffff;
        font-family: 'Poppins', sans-serif;
    }
    
    .navbar-minimal .logo span {
        color: #DC2626;
    }
    
    /* Error Container */
    .error-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }
    
    .error-card {
        background: #111111;
        border-radius: 20px;
        padding: 3rem;
        max-width: 600px;
        width: 100%;
        text-align: center;
        border: 1px solid #374151;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
    }
    
    .error-code {
        font-size: 8rem;
        font-weight: 900;
        color: #DC2626;
        line-height: 1;
        margin-bottom: 1rem;
        text-shadow: 0 0 30px rgba(220, 38, 38, 0.5);
    }
    
    .error-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: white;
        margin-bottom: 1rem;
    }
    
    .error-message {
        color: #9ca3af;
        font-size: 1.2rem;
        margin-bottom: 2rem;
    }
    
    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2.5rem;
        background: transparent;
        border: 2px solid #DC2626;
        border-radius: 40px;
        color: #DC2626;
        font-weight: 600;
        font-size: 1.1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        min-width: 200px;
        justify-content: center;
    }
    
    .btn-primary:hover {
        background: #DC2626;
        color: white;
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(220, 38, 38, 0.4);
    }
    
    .btn-icon {
        width: 20px;
        height: 20px;
        transition: transform 0.3s ease;
    }
    
    .btn-primary:hover .btn-icon {
        transform: rotate(10deg);
    }
    
    /* Footer - Red with Border Radius and Content */
    .footer-red {
        background-color: #DC2626;
        margin-top: 3rem;
        border-top-left-radius: 30px;
        border-top-right-radius: 30px;
        padding: 2rem 0;
    }
    
    .footer-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }
    
    .footer-logo {
        font-size: 1.8rem;
        font-weight: 700;
        color: #ffffff;
        font-family: 'Poppins', sans-serif;
    }
    
    .footer-logo span {
        color: #000000;
    }
    
    .footer-text {
        color: #ffffff;
        font-size: 1rem;
        text-align: center;
        opacity: 0.9;
    }
    
    .footer-copyright {
        color: #ffffff;
        font-size: 0.9rem;
        opacity: 0.7;
        margin-top: 0.5rem;
    }
    
    .footer-divider {
        width: 100px;
        height: 2px;
        background-color: rgba(255, 255, 255, 0.3);
        margin: 0.5rem 0;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .error-card {
            padding: 2rem;
        }
        .error-code {
            font-size: 6rem;
        }
        .error-title {
            font-size: 2rem;
        }
        .error-message {
            font-size: 1rem;
        }
        .btn-primary {
            width: 100%;
            padding: 0.875rem 2rem;
        }
        
        .navbar-minimal .logo {
            text-align: center;
        }
        
        .footer-content {
            padding: 0 1rem;
        }
    }
    
    @media (max-width: 480px) {
        .footer-logo {
            font-size: 1.5rem;
        }
    }
</style>
</head>

<body class="min-h-screen flex flex-col" style="background-color: #000000; font-family: 'Poppins', sans-serif;">

    <!-- Navbar - Left Aligned with Original Style -->
    <nav class="navbar-minimal">
        <div class="container mx-auto px-4">
            <div class="logo">
                <a href="/">
                    Gadi<span>Drive</span>
                </a>
            </div>
        </div>
    </nav>

    <main class="flex-grow container mx-auto px-4 max-w-screen-xl">
        <div class="error-container">
            <div class="error-card">
                <div class="error-code">404</div>
                <h1 class="error-title">Page Not Found</h1>
                <p class="error-message">The page you are looking for doesn't exist or has been moved.</p>
                <div class="error-actions">
                    <a href="<%= country ? '/' + country.country_name.toLowerCase() : '/' %>" class="btn-primary">
                        <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                        </svg>
                        <%= country ? 'Go to ' + country.country_name + ' Home' : 'Go to Home' %>
                    </a>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer - Red with Border Radius and Content -->
    <footer class="footer-red">
        <div class="footer-content">
            <div class="footer-logo">
                Gadi<span>Drive</span>
            </div>
            <div class="footer-divider"></div>
            <div class="footer-text">
                Your Global Gateway to Automotive Information
            </div>
            <div class="footer-copyright">
                © 2025 GadiDrive. All rights reserved.
            </div>
        </div>
    </footer>
</body>
</html>
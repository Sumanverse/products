<%- include('partials/head', { title: title, description: description, keywords: keywords, path: path, country: null }) %>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact GadiDrive",
  "url": "https://gadidrive.com/contact",
  "description": "<%= description %>",
  "publisher": {
    "@type": "Organization",
    "name": "GadiDrive",
    "url": "https://gadidrive.com",
    "email": "contact@gadidrive.com",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "email": "contact@gadidrive.com",
      "availableLanguage": ["English", "Nepali", "Hindi"]
    }
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://gadidrive.com/" },
      { "@type": "ListItem", "position": 2, "name": "Contact Us", "item": "https://gadidrive.com/contact" }
    ]
  }
}
</script>

<style>
    body { background-color: #000; }
    .contact-page { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
    .contact-breadcrumb { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 2rem; font-size: 0.9rem; color: #6b7280; }
    .contact-breadcrumb a { color: #9ca3af; text-decoration: none; transition: color 0.3s ease; }
    .contact-breadcrumb a:hover { color: #DC2626; }
    .contact-breadcrumb .separator { color: #4b5563; }
    .contact-breadcrumb .current { color: #DC2626; font-weight: 600; }

    .contact-hero { text-align: center; margin-bottom: 3rem; padding: 3rem 0; border-bottom: 1px solid rgba(220,38,38,0.2); }
    .contact-hero h1 { font-size: 3rem; font-weight: 800; color: white; margin-bottom: 1rem; }
    .contact-hero h1 span { color: #DC2626; }
    .contact-hero p { color: #9ca3af; font-size: 1.1rem; max-width: 600px; margin: 0 auto; line-height: 1.7; }

    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 2rem; }

    /* Info Cards */
    .contact-info { display: flex; flex-direction: column; gap: 1.5rem; }
    .info-card { background: linear-gradient(135deg, #111, #1a1a1a); border: 1px solid rgba(220,38,38,0.15); border-radius: 16px; padding: 2rem; transition: all 0.3s ease; }
    .info-card:hover { border-color: rgba(220,38,38,0.4); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(220,38,38,0.1); }
    .info-card-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
    .info-icon { width: 48px; height: 48px; background: rgba(220,38,38,0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .info-icon svg { width: 24px; height: 24px; color: #DC2626; }
    .info-card h3 { font-size: 1.2rem; font-weight: 700; color: white; margin: 0; }
    .info-card p { color: #9ca3af; line-height: 1.7; margin: 0; }
    .info-card a { color: #DC2626; text-decoration: none; font-weight: 600; transition: color 0.3s ease; }
    .info-card a:hover { color: #ef4444; }

    /* Social Links */
    .social-links { display: flex; gap: 1rem; margin-top: 0.75rem; }
    .social-link { width: 44px; height: 44px; background: rgba(220,38,38,0.1); border: 1px solid rgba(220,38,38,0.2); border-radius: 12px; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s ease; }
    .social-link:hover { background: #DC2626; border-color: #DC2626; transform: translateY(-2px); }
    .social-link svg { width: 20px; height: 20px; color: #DC2626; transition: color 0.3s ease; }
    .social-link:hover svg { color: white; }

    /* Contact Form */
    .contact-form-container { background: linear-gradient(135deg, #111, #0d0d0d); border: 1px solid rgba(220,38,38,0.15); border-radius: 20px; padding: 2.5rem; }
    .contact-form-container h2 { font-size: 1.5rem; font-weight: 700; color: white; margin-bottom: 1.5rem; }
    .form-group { margin-bottom: 1.5rem; }
    .form-group label { display: block; color: #d1d5db; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .form-group input, .form-group textarea, .form-group select {
        width: 100%; padding: 0.9rem 1.2rem; background: rgba(0,0,0,0.5); border: 1px solid #374151;
        border-radius: 12px; color: white; font-size: 1rem; font-family: 'Poppins', sans-serif;
        transition: all 0.3s ease; outline: none; box-sizing: border-box;
    }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: #DC2626; box-shadow: 0 0 0 3px rgba(220,38,38,0.1); }
    .form-group input::placeholder, .form-group textarea::placeholder { color: #4b5563; }
    .form-group textarea { min-height: 140px; resize: vertical; }
    .form-group select option { background: #111; color: white; }

    .submit-btn {
        width: 100%; padding: 1rem; background: #DC2626; color: white; border: none;
        border-radius: 12px; font-size: 1.1rem; font-weight: 700; cursor: pointer;
        transition: all 0.3s ease; font-family: 'Poppins', sans-serif;
        text-transform: uppercase; letter-spacing: 1px;
    }
    .submit-btn:hover { background: #b91c1c; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(220,38,38,0.3); }
    .submit-btn:active { transform: translateY(0); }

    .form-note { color: #6b7280; font-size: 0.85rem; margin-top: 1rem; text-align: center; }

    /* Coverage Section */
    .coverage-section { margin-top: 4rem; text-align: center; padding: 3rem 0; border-top: 1px solid rgba(220,38,38,0.15); }
    .coverage-section h2 { font-size: 1.8rem; font-weight: 700; color: white; margin-bottom: 2rem; }
    .coverage-grid { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; }
    .coverage-item { background: rgba(220,38,38,0.05); border: 1px solid rgba(220,38,38,0.1); border-radius: 12px; padding: 1.5rem 2.5rem; text-align: center; transition: all 0.3s ease; }
    .coverage-item:hover { border-color: rgba(220,38,38,0.3); transform: translateY(-2px); }
    .coverage-flag { font-size: 2rem; margin-bottom: 0.5rem; }
    .coverage-name { color: white; font-weight: 600; font-size: 1rem; }

    @media (max-width: 768px) {
        .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
        .contact-hero h1 { font-size: 2rem; }
        .coverage-grid { gap: 1rem; }
        .coverage-item { padding: 1rem 1.5rem; }
    }
</style>
</head>
<body class="min-h-screen flex flex-col bg-black text-white font-['Poppins']">
<%- include('partials/navbar-minimal') %>

<main class="flex-grow">
<div class="contact-page">

<nav class="contact-breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="separator">›</span><span class="current">Contact Us</span></nav>

<div class="contact-hero">
    <h1>Contact <span>Us</span></h1>
    <p>Have a question, feedback, or partnership inquiry? We'd love to hear from you. Reach out through any of the channels below.</p>
</div>

<div class="contact-grid">
    <!-- Left: Info Cards -->
    <div class="contact-info">
        <div class="info-card">
            <div class="info-card-header">
                <div class="info-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></div>
                <h3>Email Us</h3>
            </div>
            <p>For general inquiries, feedback, or support:</p>
            <p><a href="mailto:contact@gadidrive.com">contact@gadidrive.com</a></p>
        </div>

        <div class="info-card">
            <div class="info-card-header">
                <div class="info-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></div>
                <h3>Business & Partnerships</h3>
            </div>
            <p>Interested in advertising, collaboration, or partnership opportunities?</p>
            <p><a href="mailto:business@gadidrive.com">business@gadidrive.com</a></p>
        </div>

        <div class="info-card">
            <div class="info-card-header">
                <div class="info-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
                <h3>Follow Us</h3>
            </div>
            <p>Stay updated with the latest automotive news:</p>
            <div class="social-links">
                <a href="https://facebook.com/gadidrive" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Facebook">
                    <svg fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://instagram.com/gadidrive" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Instagram">
                    <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
                <a href="https://youtube.com/@gadidrive" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="YouTube">
                    <svg fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
            </div>
        </div>
    </div>

    <!-- Right: Contact Form -->
    <div class="contact-form-container">
        <h2>Send Us a Message</h2>
        <form id="contact-form" action="javascript:void(0);" method="POST">
            <div class="form-group">
                <label for="contact-name">Your Name</label>
                <input type="text" id="contact-name" name="name" placeholder="Enter your full name" required>
            </div>
            <div class="form-group">
                <label for="contact-email">Email Address</label>
                <input type="email" id="contact-email" name="email" placeholder="your@email.com" required>
            </div>
            <div class="form-group">
                <label for="contact-subject">Subject</label>
                <select id="contact-subject" name="subject">
                    <option value="general">General Inquiry</option>
                    <option value="feedback">Feedback</option>
                    <option value="bug">Report a Bug</option>
                    <option value="partnership">Partnership / Advertising</option>
                    <option value="data">Data Correction Request</option>
                    <option value="other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label for="contact-message">Message</label>
                <textarea id="contact-message" name="message" placeholder="Tell us what's on your mind..." required></textarea>
            </div>
            <button type="submit" class="submit-btn" onclick="alert('Thank you for your message! We will get back to you soon.')">Send Message</button>
            <p class="form-note">We typically respond within 24-48 hours.</p>
        </form>
    </div>
</div>

<!-- Coverage Section -->
<div class="coverage-section">
    <h2>We Cover Automotive Markets In</h2>
    <div class="coverage-grid">
        <div class="coverage-item"><div class="coverage-flag">🇳🇵</div><div class="coverage-name">Nepal</div></div>
        <div class="coverage-item"><div class="coverage-flag">🇮🇳</div><div class="coverage-name">India</div></div>
        <div class="coverage-item"><div class="coverage-flag">🇧🇩</div><div class="coverage-name">Bangladesh</div></div>
        <div class="coverage-item"><div class="coverage-flag">🇵🇰</div><div class="coverage-name">Pakistan</div></div>
        <div class="coverage-item"><div class="coverage-flag">🇺🇸</div><div class="coverage-name">USA</div></div>
    </div>
</div>

</div>
</main>
<%- include('partials/footer', { country: null, allCountries: allCountries, allVehicleTypes: allVehicleTypes || [], minimal: true }) %>
</body>
</html>

<%
    const countryPrefix = typeof country !== 'undefined' && country ? '/' + country.country_name.toLowerCase() : '';
    const articleUrl = countryPrefix ? 
        `${countryPrefix}/news/${article.Article_id}-${article.Article_title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}` :
        `/news/${article.Article_id}-${article.Article_title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
%>

<a href="<%= articleUrl %>" class="block group h-full mb-4" itemscope itemtype="https://schema.org/NewsArticle">
    <meta itemprop="mainEntityOfPage" content="<%= articleUrl %>">
    <meta itemprop="datePublished" content="<%= new Date(article.published_date).toISOString() %>">
    <meta itemprop="author" content="GadiDrive <%= typeof country !== 'undefined' && country ? country.country_name : 'Nepal' %>">
    
    <div class="article-card 
        relative bg-[#0d0d0d] border border-white/10 rounded-2xl overflow-hidden flex flex-row
        transition-all duration-500 ease-out
        hover:border-red-600/50 hover:shadow-[0_20px_50px_-15px_rgba(220,38,38,0.3)]
        h-36 md:h-44">

        <div class="w-1/3 flex-shrink-0 relative overflow-hidden bg-gradient-to-r from-white/[0.03] to-transparent p-2"> 
            <% if (article.Article_main_image) { %>
                <img src="<%= article.Article_main_image %>" 
                    itemprop="image"
                    alt="<%= article.Article_title %>"
                    class="w-full h-full object-cover rounded-xl transition-all duration-700 ease-in-out 
                           group-hover:scale-110 group-hover:rotate-1"
                    loading="lazy">
            <% } else { %>
                <div class="w-full h-full bg-white/5 flex items-center justify-center rounded-xl">
                    <span class="text-4xl font-black text-white/5 uppercase">
                        <%= (typeof country !== 'undefined' && country ? country.country_name.charAt(0) : 'G') %>
                    </span>
                </div>
            <% } %>

            <div class="absolute inset-0 bg-gradient-to-t from-red-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>

        <div class="w-2/3 p-3 flex flex-col h-full">
            <div class="bg-[#151515] border border-white/5 rounded-xl p-3 md:p-4 flex flex-col justify-between h-full transition-all duration-300 group-hover:bg-[#1a0505] group-hover:border-red-600/30">
                
                <div class="overflow-hidden">
                    <% if (article.category_name) { %>
                        <span class="text-[9px] font-black text-red-500 uppercase tracking-widest mb-1 block">
                            <%= article.category_name %>
                        </span>
                        <meta itemprop="articleSection" content="<%= article.category_name %>">
                    <% } %>
                    <h3 itemprop="headline" class="text-sm md:text-base font-black text-white leading-tight transition-colors duration-300 group-hover:text-red-500 line-clamp-2">
                        <%= article.Article_title %>
                    </h3>
                </div>

                <div class="flex justify-between items-center mt-auto">
                    <div class="flex flex-col">
                        <time datetime="<%= new Date(article.published_date).toISOString() %>" 
                              class="text-[10px] md:text-[11px] font-bold text-gray-500 transition-colors duration-300 group-hover:text-white">
                            <%= new Date(article.published_date).toLocaleDateString('en-US', {
                                month: 'short', day: 'numeric', year: 'numeric'
                            }) %>
                        </time>
                        <% if (article.reading_time) { %>
                            <span class="text-[9px] text-gray-600 font-medium transition-colors duration-300 group-hover:text-gray-400"><%= article.reading_time %> min read</span>
                        <% } %>
                    </div>

                    <div class="bg-white/5 px-2.5 py-1.5 rounded-lg border border-white/5 transition-all duration-300 group-hover:bg-red-600 group-hover:border-red-600 group-hover:shadow-[0_0_15px_rgba(220,38,38,0.4)]">
                        <span class="text-[9px] font-black text-white flex items-center gap-1">
                            READ <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/></svg>
                        </span>
                    </div>
                </div>

            </div>
        </div>

        <div class="absolute bottom-0 left-0 h-[3px] w-0 bg-red-600 transition-all duration-700 group-hover:w-full"></div>
    </div>
</a>
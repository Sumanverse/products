              : (typeof locals !== 'undefined' && locals.allCountries ? locals.allCountries : []);
          %>
          <% if (displayCountries && displayCountries.length > 0) { %>
            <div class="footer-select-wrapper">
              <label for="footer-country-selector" class="sr-only">Select Country</label>
              <select id="footer-country-selector" class="footer-country-select">
                <option value="" disabled selected>🌍 Select Country</option>
                <% displayCountries.forEach(c => { %>
                  <option value="<%= c.country_name.toLowerCase() %>"
                    <%= typeof country !== 'undefined' && country && country.country_name === c.country_name ? 'selected' : '' %>>
                    <%= c.country_name %> (<%= c.currency_symbol %>)
                  </option>
                <% }); %>
              </select>
              <div class="footer-select-chevron">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
              </div>
            </div>
            <p class="footer-current-country">
              <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Currently viewing:
              <strong><%= typeof country !== 'undefined' && country ? country.country_name + ' (' + country.currency_symbol + ')' : 'Global' %></strong>
            </p>
          <% } else { %>
            <p style="font-size:13px; color:rgba(255,255,255,0.3);">No countries available</p>
          <% } %>

          <!-- Vehicle type pills if available -->
          <% if (footerVehicleTypes && footerVehicleTypes.length > 1) { %>
            <div style="margin-top:28px;">
              <div class="footer-col-title">Browse By Type</div>
              <div style="display:flex; flex-wrap:wrap; gap:8px;">
                <% footerVehicleTypes.forEach(vt => { %>
                  <a href="<%= footerCountryPrefix %>/<%= vt.vehicle_type_name %>/brands"
                     style="display:inline-block; padding:6px 14px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:20px; font-size:11px; font-weight:600; color:rgba(255,255,255,0.5); text-decoration:none; letter-spacing:0.05em; text-transform:capitalize; transition:all 0.2s;"
                     onmouseover="this.style.background='rgba(220,38,38,0.15)';this.style.borderColor='rgba(220,38,38,0.4)';this.style.color='#fff';"
                     onmouseout="this.style.background='rgba(255,255,255,0.05)';this.style.borderColor='rgba(255,255,255,0.1)';this.style.color='rgba(255,255,255,0.5)';">
                    <%= vt.vehicle_type_name %>
                  </a>
                <% }); %>
              </div>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Divider -->
      <div class="footer-divider"></div>

      <!-- Bottom Bar -->
      <div class="footer-bottom">
        <p class="footer-copyright">
          © <%= new Date().getFullYear() %> <strong>GadiDrive</strong>. All rights reserved.
        </p>
        <p class="footer-made-with">
          Made with <span>♥</span> for automotive lovers worldwide
        </p>
      </div>

    <% } %>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const countrySelector = document.getElementById('footer-country-selector');
    if (countrySelector) {
      countrySelector.addEventListener('change', function () {
        const selectedCountry = this.value;
        if (selectedCountry) {
          window.location.href = '/' + selectedCountry + '/';
        }
      });
    }
  });
</script>

<footer class="w-full mt-24 gadidrive-footer" role="contentinfo">

  <style>
    .gadidrive-footer {
      background: #0A0A0A;
      border-top-left-radius: 48px;
      border-top-right-radius: 48px;
      overflow: hidden;
      position: relative;
    }

    /* Subtle red glow at top edge */
    .gadidrive-footer::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent 0%, #DC2626 30%, #FF4444 50%, #DC2626 70%, transparent 100%);
      z-index: 2;
    }

    /* Background texture */
    .gadidrive-footer::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(ellipse 80% 60% at 50% -10%, rgba(220,38,38,0.12) 0%, transparent 70%),
        radial-gradient(ellipse 40% 30% at 90% 80%, rgba(220,38,38,0.06) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    .footer-inner {
      position: relative;
      z-index: 1;
      max-width: 1280px;
      margin: 0 auto;
      padding: 64px 48px 40px;
    }

    /* ── BRAND ── */
    .footer-brand-name {
      font-family: 'Bebas Neue', 'Arial Black', Impact, sans-serif;
      font-size: 52px;
      line-height: 1;
      letter-spacing: 2px;
      color: #FFFFFF;
    }
    .footer-brand-name span { color: #DC2626; }

    .footer-tagline-primary {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      margin-top: 10px;
    }

    .footer-tagline-sub {
      font-size: 9px;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.25);
      margin-top: 4px;
      font-style: italic;
    }

    /* ── SOCIAL ICONS ── */
    .footer-socials {
      display: flex;
      gap: 10px;
      margin-top: 24px;
    }

    .footer-social-link {
      width: 38px;
      height: 38px;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      transition: all 0.25s ease;
      flex-shrink: 0;
    }

    .footer-social-link:hover {
      background: #DC2626;
      border-color: #DC2626;
      color: #fff;
      transform: translateY(-2px);
    }

    .footer-social-link svg {
      width: 16px;
      height: 16px;
    }

    /* ── COLUMN HEADINGS ── */
    .footer-col-title {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #DC2626;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(220,38,38,0.25);
    }

    /* ── LINKS ── */
    .footer-link {
      display: flex;
      align-items: center;
      gap: 8px;
      color: rgba(255,255,255,0.55);
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      padding: 5px 0;
      transition: all 0.2s ease;
      border-bottom: none;
    }

    .footer-link::before {
      content: '';
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: rgba(220,38,38,0.4);
      flex-shrink: 0;
      transition: all 0.2s ease;
    }

    .footer-link:hover {
      color: #fff;
      padding-left: 4px;
    }

    .footer-link:hover::before {
      background: #DC2626;
    }

    /* ── COUNTRY SELECTOR ── */
    .footer-select-wrapper {
      position: relative;
    }

    .footer-country-select {
      width: 100%;
      background: rgba(255,255,255,0.04);
      color: rgba(255,255,255,0.8);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px;
      padding: 12px 40px 12px 16px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      appearance: none;
      -webkit-appearance: none;
      outline: none;
      transition: all 0.25s ease;
    }

    .footer-country-select:hover,
    .footer-country-select:focus {
      border-color: rgba(220,38,38,0.5);
      background: rgba(220,38,38,0.06);
    }

    .footer-country-select option {
      background: #1a1a1a;
      color: #fff;
    }

    .footer-select-chevron {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
      color: rgba(255,255,255,0.4);
    }

    .footer-current-country {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: rgba(255,255,255,0.3);
      margin-top: 10px;
    }

    .footer-current-country strong {
      color: rgba(255,255,255,0.6);
    }

    /* ── NEWSLETTER PILL ── */
    .footer-newsletter {
      margin-top: 24px;
      background: rgba(220,38,38,0.08);
      border: 1px solid rgba(220,38,38,0.2);
      border-radius: 12px;
      padding: 16px;
    }

    .footer-newsletter p {
      font-size: 11px;
      color: rgba(255,255,255,0.4);
      margin: 0 0 10px;
      line-height: 1.5;
    }

    .footer-newsletter-row {
      display: flex;
      gap: 8px;
    }

    .footer-newsletter-input {
      flex: 1;
      background: rgba(0,0,0,0.3);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      padding: 9px 12px;
      font-size: 12px;
      color: #fff;
      outline: none;
      min-width: 0;
      transition: border-color 0.2s;
    }

    .footer-newsletter-input::placeholder { color: rgba(255,255,255,0.25); }
    .footer-newsletter-input:focus { border-color: rgba(220,38,38,0.5); }

    .footer-newsletter-btn {
      background: #DC2626;
      border: none;
      border-radius: 8px;
      padding: 9px 14px;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s, transform 0.15s;
    }

    .footer-newsletter-btn:hover { background: #b91c1c; transform: scale(1.02); }

    /* ── DIVIDER ── */
    .footer-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.07) 20%, rgba(255,255,255,0.07) 80%, transparent);
      margin: 40px 0 24px;
    }

    /* ── BOTTOM BAR ── */
    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .footer-copyright {
      font-size: 12px;
      color: rgba(255,255,255,0.25);
    }

    .footer-copyright strong { color: rgba(255,255,255,0.5); }

    .footer-made-with {
      font-size: 12px;
      color: rgba(255,255,255,0.2);
    }

    .footer-made-with span { color: #DC2626; }

    /* ── MINIMAL VARIANT ── */
    .footer-minimal-brand {
      font-family: 'Bebas Neue', 'Arial Black', Impact, sans-serif;
      font-size: 64px;
      line-height: 1;
      letter-spacing: 3px;
      color: #FFFFFF;
    }

    .footer-minimal-brand span { color: #DC2626; }

    .footer-minimal-tagline {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.4);
      margin-top: 10px;
    }

    .footer-minimal-sub {
      font-size: 9px;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.2);
      margin-top: 4px;
      font-style: italic;
    }

    .footer-minimal-nav {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0 32px;
      margin-top: 28px;
    }

    .footer-minimal-nav-link {
      color: rgba(255,255,255,0.45);
      text-decoration: none;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 6px 0;
      transition: color 0.2s;
      position: relative;
    }

    .footer-minimal-nav-link::after {
      content: '';
      position: absolute;
      bottom: 4px;
      left: 0; right: 0;
      height: 1px;
      background: #DC2626;
      transform: scaleX(0);
      transition: transform 0.2s ease;
    }

    .footer-minimal-nav-link:hover { color: #fff; }
    .footer-minimal-nav-link:hover::after { transform: scaleX(1); }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .footer-inner { padding: 48px 24px 32px; }
      .footer-grid { grid-template-columns: 1fr 1fr !important; gap: 36px !important; }
      .footer-brand-col { grid-column: 1 / -1; }
      .footer-bottom { flex-direction: column; text-align: center; }
    }

    @media (max-width: 480px) {
      .footer-grid { grid-template-columns: 1fr !important; }
      .footer-brand-name { font-size: 44px; }
    }

    /* Bebas Neue font */
    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap');
  </style>


<a href="<%= link %>" class="block group h-full" itemscope itemtype="https://schema.org/Brand">
    <div class="category-brand-card 
        relative bg-[#0d0d0d] border border-white/10 rounded-2xl overflow-hidden 
        transition-all duration-500 ease-out
        hover:border-red-600/50 hover:shadow-[0_20px_50px_-15px_rgba(220,38,38,0.3)]
        h-full flex flex-col">
        <%
            const imagePath = item.image_path || item.vehicle_type_photo_path || item.photo_path || item.brand_photo_path || null;
            const name = item.name || item.vehicle_type_name || item.brand_name || item.category_name || 'Unknown';
        %>
        
        <div class="relative w-full h-32 sm:h-44 md:h-52 flex items-center justify-center bg-gradient-to-b from-white/[0.03] to-transparent p-4 md:p-6"> 
            <% if (imagePath) { %>
                <img src="<%= imagePath %>" 
                    alt="<%= name %> logo" 
                    itemprop="logo"
                    loading="<%= (typeof index !== 'undefined' && index < 10) ? 'eager' : 'lazy' %>"
                    fetchpriority="<%= (typeof index !== 'undefined' && index < 3) ? 'high' : 'auto' %>"
                    width="200"
                    height="200"
                    class="w-full h-full object-contain transition-all duration-700 ease-in-out 
                           group-hover:scale-110 group-hover:-rotate-2">
            <% } else { %>
                <div class="w-full h-full flex items-center justify-center">
                    <span class="text-4xl md:text-6xl font-black text-white/5 select-none"><%= name.charAt(0) %></span>
                </div>
            <% } %>
            <div class="absolute bottom-0 inset-x-0 h-1/3 bg-gradient-to-t from-red-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        </div>

        <div class="px-2 pb-2 md:px-3 md:pb-3 mt-auto">
            <div class="bg-[#151515] border border-white/5 rounded-xl p-2.5 md:p-3.5 flex items-center justify-between transition-all duration-300 group-hover:bg-[#1a0505] group-hover:border-red-600/30">
                
                <div class="flex flex-col overflow-hidden">
                    <!-- ✅ FIXED: Full brand name dekhaunxa — split logic hatayo -->
                    <h3 class="text-[13px] sm:text-[15px] md:text-lg font-black text-white tracking-tight leading-none transition-colors truncate" itemprop="name">
                        <span class="group-hover:text-red-500 transition-colors duration-300"><%= name %></span>
                    </h3>
                </div>

                <div class="bg-white/5 px-2 py-1 md:px-3 md:py-1.5 rounded-lg border border-white/5 transition-all duration-300 group-hover:bg-red-600 group-hover:border-red-600 group-hover:shadow-[0_0_15px_rgba(220,38,38,0.4)] flex-shrink-0">
                    <span class="text-[9px] md:text-[10px] font-black text-white flex items-center gap-1 md:gap-1.5">
                        <span class="hidden xs:block">EXPLORE</span> 
                        <svg class="w-2.5 h-2.5 md:w-3 md:h-3 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/>
                        </svg>
                    </span>
                </div>
            </div>
        </div>
        <div class="absolute bottom-0 left-0 h-[2px] md:h-[3px] w-0 bg-red-600 transition-all duration-700 group-hover:w-full"></div>
    </div>
</a>
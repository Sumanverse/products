<!-- views/partials/breadcrumb.ejs -->
<nav class="breadcrumb-nav" aria-label="Breadcrumb">
    <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="breadcrumb-item">
            <a href="<%= locals.countryPrefix || '/' %>" itemprop="item" class="breadcrumb-link home-text">
                <span itemprop="name">Home</span>
            </a>
            <meta itemprop="position" content="1" />
        </li>
        
        <% if (locals.breadcrumbs && breadcrumbs.length > 0) { %>
            <% breadcrumbs.forEach(function(crumb, index) { %>
                <li class="breadcrumb-separator">
                    <i class="fas fa-chevron-right"></i>
                </li>
                
                <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="breadcrumb-item">
                    <% if (index === breadcrumbs.length - 1) { %>
                        <span itemprop="name" class="breadcrumb-current" aria-current="page"><%= crumb.name %></span>
                        <meta itemprop="item" content="<%= crumb.url %>" />
                    <% } else { %>
                        <a href="<%= crumb.url %>" itemprop="item" class="breadcrumb-link">
                            <span itemprop="name"><%= crumb.name %></span>
                        </a>
                    <% } %>
                    <meta itemprop="position" content="<%= index + 2 %>" />
                </li>
            <% }); %>
        <% } %>
    </ol>
</nav>

<style>
    .breadcrumb-nav {
        margin: 0.2rem 0 0.8rem;
        padding: 0.4rem 0;
        background: transparent;
        display: block;
        max-width: 100%;
        overflow-x: auto;
        scrollbar-width: none;
    }
    .breadcrumb-nav::-webkit-scrollbar {
        display: none;
    }
    .breadcrumb-list {
        display: flex;
        align-items: center;
        list-style: none;
        padding: 0;
        margin: 0;
        white-space: nowrap;
    }
    .breadcrumb-item {
        display: flex;
        align-items: center;
    }
    .breadcrumb-link {
        color: #9ca3af;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    .breadcrumb-link:hover {
        color: #ffffff;
    }
    .breadcrumb-separator {
        margin: 0 0.6rem;
        color: #4b5563;
        font-size: 0.65rem;
        opacity: 0.7;
    }
    .breadcrumb-current {
        color: #DC2626;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.01em;
    }
    @media (max-width: 768px) {
        .breadcrumb-nav {
            margin-bottom: 0.5rem;
        }
        .breadcrumb-link, .breadcrumb-current {
            font-size: 0.85rem;
        }
    }
</style>

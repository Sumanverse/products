<%- include('../partials/footer', { 
    country: country,
    allCountries: allCountries,
    allVehicleTypes: []
}) %>

<script>
    // Global variables
    let selectedModels = [];
    let vehicleTypes = <%- JSON.stringify(vehicleTypes || []) %>;
    let currentComparisonData = null;
    let currentCountry = '<%= country ? country.country_name.toLowerCase() : "" %>';
    let currencySymbol = '<%= currencySymbol || "रू" %>';

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
        initializeVehicleSelection();
        setupEventListeners();
        
        // Check for URL parameters to load shared comparison
        loadComparisonFromUrl();
        
        updateCompareButton();
    });

    // Generate Share URL with query parameters
    function getShareUrl() {
        if (!currentComparisonData || !currentComparisonData.models || currentComparisonData.models.length === 0) {
            return window.location.href.split('?')[0];
        }
        
        const baseUrl = window.location.href.split('?')[0];
        const params = new URLSearchParams();
        
        currentComparisonData.models.forEach((model, index) => {
            if (model && model.id) {
                params.set(`v${index + 1}`, model.id);
            }
        });
        
        return `${baseUrl}?${params.toString()}`;
    }

    // Load comparison from URL parameters
    async function loadComparisonFromUrl() {
        const urlParams = new URLSearchParams(window.location.search);
        const modelIdsToLoad = [];
        
        // Support up to 4 models from v1, v2, v3, v4
        for (let i = 1; i <= 4; i++) {
            const val = urlParams.get(`v${i}`);
            if (val) modelIdsToLoad.push(val);
        }
        
        if (modelIdsToLoad.length >= 2) {
            // Adjust dropdown count if necessary
            const countSelect = document.getElementById('vehicle-count');
            if (modelIdsToLoad.length > parseInt(countSelect.value)) {
                countSelect.value = modelIdsToLoad.length;
                updateVehicleSelection();
            }
            
            // Show loading spinner
            document.getElementById('loading-spinner').style.display = 'block';
            
            try {
                // Fetch directly
                const response = await fetch(`/compare?countryname=${currentCountry}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ modelIds: modelIdsToLoad })
                });

                const data = await response.json();
                
                if (data.success) {
                    currentComparisonData = data.comparisonData;
                    displayComparisonResults(data.comparisonData);
                    document.getElementById('share-button').style.display = 'flex';
                    
                    // Note: We don't populate the individual dropdowns here because
                    // it would require extra API calls to find the brand/type for each model,
                    // but we do show the results immediately!
                }
            } catch (error) {
                console.error('Failed to load shared comparison:', error);
            } finally {
                document.getElementById('loading-spinner').style.display = 'none';
            }
        }
    }

    // Initialize vehicle selection boxes
    function initializeVehicleSelection() {
        const vehicleCount = document.getElementById('vehicle-count');
        const vehicleSelection = document.getElementById('vehicle-selection');
        
        vehicleCount.addEventListener('change', updateVehicleSelection);
        updateVehicleSelection();
    }

    // Update vehicle selection boxes based on count
    function updateVehicleSelection() {
        const count = parseInt(document.getElementById('vehicle-count').value);
        const vehicleSelection = document.getElementById('vehicle-selection');
        
        vehicleSelection.innerHTML = '';
        selectedModels = Array(count).fill(null);
        
        for (let i = 0; i < count; i++) {
            const selectionBox = document.createElement('div');
            selectionBox.className = 'vehicle-selector-box fade-in';
            selectionBox.innerHTML = `
                <div class="vehicle-number">${i + 1}</div>
                <div class="selection-group">
                    <label class="selection-label">Vehicle Type</label>
                    <select class="selection-dropdown vehicle-type-select" data-index="${i}" onchange="onVehicleTypeChange(${i})">
                        <option value="">Select Type</option>
                        ${vehicleTypes.map(type => 
                            `<option value="${type.vehicle_type_id}">${type.vehicle_type_name}</option>`
                        ).join('')}
                </select>
                </div>
                
                <div class="selection-group">
                    <label class="selection-label">Brand</label>
                    <select class="selection-dropdown brand-select" data-index="${i}" onchange="onBrandChange(${i})" disabled>
                        <option value="">Select Brand</option>
                    </select>
                </div>
                
                <div class="selection-group">
                    <label class="selection-label">Model</label>
                    <select class="selection-dropdown model-select" data-index="${i}" onchange="onModelChange(${i})" disabled>
                        <option value="">Select Model</option>
                    </select>
                </div>
                
                <div id="selected-model-${i}" class="selected-model-display">
                    <!-- Selected model will be shown here -->
                </div>
            `;
            vehicleSelection.appendChild(selectionBox);
        }
        
        updateCompareButton();
    }

    // Handle vehicle type change
    async function onVehicleTypeChange(index) {
        const vehicleTypeSelect = document.querySelector(`.vehicle-type-select[data-index="${index}"]`);
        const brandSelect = document.querySelector(`.brand-select[data-index="${index}"]`);
        const modelSelect = document.querySelector(`.model-select[data-index="${index}"]`);
        const selectedDisplay = document.getElementById(`selected-model-${index}`);
        
        const vehicleTypeId = vehicleTypeSelect.value;
        
        // Reset downstream selections
        brandSelect.innerHTML = '<option value="">Select Brand</option>';
        brandSelect.disabled = true;
        modelSelect.innerHTML = '<option value="">Select Model</option>';
        modelSelect.disabled = true;
        selectedDisplay.style.display = 'none';
        selectedModels[index] = null;
        
        if (!vehicleTypeId) {
            updateCompareButton();
            return;
        }
        
        try {
            // Show loading state
            brandSelect.innerHTML = '<option value="">Loading brands...</option>';
            
            // Fetch brands for selected vehicle type with country filter
            const response = await fetch(`/compare/brands/${vehicleTypeId}?countryname=${currentCountry}`);
            const data = await response.json();
            
            if (data.success) {
                brandSelect.innerHTML = '<option value="">Select Brand</option>' + 
                    data.brands.map(brand => 
                        `<option value="${brand.brand_id}">${brand.name}</option>`
                    ).join('');
                brandSelect.disabled = false;
            }
        } catch (error) {
            console.error('Error fetching brands:', error);
            brandSelect.innerHTML = '<option value="">Error loading brands</option>';
        }
        
        updateCompareButton();
    }

    // Handle brand change
    async function onBrandChange(index) {
        const vehicleTypeSelect = document.querySelector(`.vehicle-type-select[data-index="${index}"]`);
        const brandSelect = document.querySelector(`.brand-select[data-index="${index}"]`);
        const modelSelect = document.querySelector(`.model-select[data-index="${index}"]`);
        const selectedDisplay = document.getElementById(`selected-model-${index}`);
        
        const vehicleTypeId = vehicleTypeSelect.value;
        const brandId = brandSelect.value;
        
        // Reset downstream selections
        modelSelect.innerHTML = '<option value="">Select Model</option>';
        modelSelect.disabled = true;
        selectedDisplay.style.display = 'none';
        selectedModels[index] = null;
        
        if (!vehicleTypeId || !brandId) {
            updateCompareButton();
            return;
        }
        
        try {
            // Show loading state
            modelSelect.innerHTML = '<option value="">Loading models...</option>';
            
            // Fetch models for selected brand and vehicle type with country filter
            const response = await fetch(`/compare/models/${vehicleTypeId}/${brandId}?countryname=${currentCountry}`);
            const data = await response.json();
            
            if (data.success) {
                modelSelect.innerHTML = '<option value="">Select Model</option>' + 
                    data.models.map(model => 
                        `<option value="${model.id}">${model.model_name}</option>`
                    ).join('');
                modelSelect.disabled = false;
            }
        } catch (error) {
            console.error('Error fetching models:', error);
            modelSelect.innerHTML = '<option value="">Error loading models</option>';
        }
        
        updateCompareButton();
    }

    // Handle model change
    async function onModelChange(index) {
        const modelSelect = document.querySelector(`.model-select[data-index="${index}"]`);
        const selectedDisplay = document.getElementById(`selected-model-${index}`);
        
        const modelId = modelSelect.value;
        
        if (!modelId) {
            selectedDisplay.style.display = 'none';
            selectedModels[index] = null;
            updateCompareButton();
            return;
        }
        
        try {
            // Show loading state
            selectedDisplay.innerHTML = '<div class="text-center py-2">Loading model details...</div>';
            selectedDisplay.style.display = 'block';
            
            // Fetch model details with country filter
            const response = await fetch(`/compare/model/${modelId}?countryname=${currentCountry}`);
            const data = await response.json();
            
            if (data.success) {
                const model = data.model;
                selectedModels[index] = model;
                
                selectedDisplay.innerHTML = `
                    <div class="selected-model-content">
                        <img src="${model.model_image || '/images/placeholder.jpg'}" 
                             alt="${model.model_name}" 
                             class="selected-model-image"
                             onerror="this.src='/images/placeholder.jpg'">
                        <div class="model-info-compact">
                            <div class="model-name-compact">${model.brand_name} ${model.model_name}</div>
                            <div class="model-price-compact">
                                ${model.formatted_price || currencySymbol + ' ' + (model.starting_price ? new Intl.NumberFormat('en-IN').format(model.starting_price) : 'Price not available')}
                            </div>
                        </div>
                        <button class="remove-model-btn" onclick="removeModel(${index})" aria-label="Remove model">
                            Remove
                        </button>
                    </div>
                `;
                selectedDisplay.style.display = 'block';
            }
        } catch (error) {
            console.error('Error fetching model details:', error);
            selectedDisplay.innerHTML = '<div class="text-center py-2 text-red-400">Error loading model</div>';
        }
        
        updateCompareButton();
    }

    // Remove selected model
    function removeModel(index) {
        const vehicleTypeSelect = document.querySelector(`.vehicle-type-select[data-index="${index}"]`);
        const brandSelect = document.querySelector(`.brand-select[data-index="${index}"]`);
        const modelSelect = document.querySelector(`.model-select[data-index="${index}"]`);
        const selectedDisplay = document.getElementById(`selected-model-${index}`);
        
        // Reset all selections for this box
        vehicleTypeSelect.value = '';
        brandSelect.innerHTML = '<option value="">Select Brand</option>';
        brandSelect.disabled = true;
        modelSelect.innerHTML = '<option value="">Select Model</option>';
        modelSelect.disabled = true;
        selectedDisplay.style.display = 'none';
        selectedModels[index] = null;
        
        updateCompareButton();
    }

    // Update compare button state
    function updateCompareButton() {
        const selectedCount = selectedModels.filter(model => model !== null).length;
        const compareButton = document.getElementById('compare-button');
        const compareButtonText = document.getElementById('compare-button-text');
        const shareButton = document.getElementById('share-button');
        
        if (selectedCount >= 2) {
            compareButton.disabled = false;
            compareButtonText.textContent = `Compare ${selectedCount} Vehicles`;
        } else {
            compareButton.disabled = true;
            compareButtonText.textContent = 'Select at least 2 Vehicles';
        }
        
        // Hide share button when no comparison is shown
        shareButton.style.display = 'none';
    }

    // Setup event listeners
    function setupEventListeners() {
        document.getElementById('compare-button').addEventListener('click', performComparison);
    }

    // Perform comparison
    async function performComparison() {
        const selectedCount = selectedModels.filter(model => model !== null).length;
        
        if (selectedCount < 2) {
            alert('Please select at least 2 vehicles to compare');
            return;
        }

        // Show loading spinner
        document.getElementById('loading-spinner').style.display = 'block';
        document.getElementById('comparison-results').style.display = 'none';
        document.getElementById('share-button').style.display = 'none';

        try {
            const modelIds = selectedModels.filter(model => model !== null).map(model => model.id);
            
            const response = await fetch(`/compare?countryname=${currentCountry}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ modelIds: modelIds })
            });

            const data = await response.json();
            
            if (data.success) {
                currentComparisonData = data.comparisonData;
                displayComparisonResults(data.comparisonData);
                document.getElementById('share-button').style.display = 'flex';
            } else {
                alert(data.message || 'Error performing comparison');
            }
        } catch (error) {
            console.error('Comparison error:', error);
            alert('Error performing comparison');
        } finally {
            document.getElementById('loading-spinner').style.display = 'none';
        }
    }

    // Display comparison results
    function displayComparisonResults(comparisonData) {
        const resultsSection = document.getElementById('comparison-results');
        const comparisonHeader = document.getElementById('comparison-header');
        const comparisonBody = document.getElementById('comparison-body');
        const conclusionContent = document.getElementById('conclusion-content');
        const comparisonTitle = document.getElementById('comparison-title');
        
        // Update title with compared vehicles
        const titleModels = comparisonData.models.map(model => `${model.brand} ${model.name}`).join(' vs ');
        comparisonTitle.textContent = `Comparing ${titleModels}`;

        // Clear previous results
        comparisonHeader.innerHTML = '<th class="spec-header">Specifications</th>';
        comparisonBody.innerHTML = '';
        
        // Find winner (highest score)
        const winnerIndex = comparisonData.models.reduce((maxIndex, model, index, array) => 
            model.score > array[maxIndex].score ? index : maxIndex, 0
        );
        
        // Define which specs should show data vs ticks
        const specsWithData = new Set([
            'Engine Type', 'Power', 'Torque', 'Ground Clearance', 'Dimensions',
            'Drive Type', 'Seating Capacity', 'Total Airbags', 'Boot Space',
            'Mileage', 'Range', 'Battery Capacity', 'Cylinders', 'Fuel Tank Capacity',
            'Price', 'Safety Rating', 'Launch Year', 'Engine'
        ]);
        
        // Create table headers with prices and CLICKABLE NAMES (NO UNDERLINE)
        comparisonData.models.forEach((model, index) => {
            const headerCell = document.createElement('th');
            headerCell.className = `vehicle-header ${index === winnerIndex ? 'winner' : ''}`;
            
            const price = model.basicInfo.starting_price || 'Price not available';
            const modelName = model.name || '';
            const brandName = model.brand || '';
            
            // Create URL-friendly slugs
            const modelSlug = modelName.toLowerCase()
                .replace(/ /g, '-')
                .replace(/[^a-z0-9-]/g, '')
                .replace(/-+/g, '-');
                
            const brandSlug = brandName.toLowerCase()
                .replace(/ /g, '-')
                .replace(/[^a-z0-9-]/g, '')
                .replace(/-+/g, '-');
            
            // Create the model details URL with brand prefix
            const modelDetailsUrl = currentCountry ? 
                `/${currentCountry}/${model.vehicle_type_name || 'car'}/brand/${brandSlug}/${modelSlug}/` : 
                `/${model.vehicle_type_name || 'car'}/brand/${brandSlug}/${modelSlug}/`;
            
            if (index === winnerIndex) {
                headerCell.innerHTML = `
                    <div class="winner-badge">Winner</div>
                    <a href="${modelDetailsUrl}" 
                       class="vehicle-name" 
                       style="text-decoration: none !important;" 
                       onmouseover="this.style.color='#dc2626'; this.style.textDecoration='none';" 
                       onmouseout="this.style.color='white'; this.style.textDecoration='none';"
                       title="View ${brandName} ${modelName} details">
                        ${modelName}
                    </a>
                    <div class="vehicle-brand">${brandName}</div>
                    <div class="vehicle-price">
                        ${price}
                    </div>
                    <a href="${modelDetailsUrl}" class="view-details-btn" title="View full details of ${brandName} ${modelName}">
                        <i class="fas fa-external-link-alt mr-2"></i>View Details
                    </a>
                `;
            } else {
                headerCell.innerHTML = `
                    <a href="${modelDetailsUrl}" 
                       class="vehicle-name" 
                       style="text-decoration: none !important;" 
                       onmouseover="this.style.color='#dc2626'; this.style.textDecoration='none';" 
                       onmouseout="this.style.color='white'; this.style.textDecoration='none';"
                       title="View ${brandName} ${modelName} details">
                        ${modelName}
                    </a>
                    <div class="vehicle-brand">${brandName}</div>
                    <div class="vehicle-price">
                        ${price}
                    </div>
                    <a href="${modelDetailsUrl}" class="view-details-btn" title="View full details of ${brandName} ${modelName}">
                        <i class="fas fa-external-link-alt mr-2"></i>View Details
                    </a>
                `;
            }
            
            comparisonHeader.appendChild(headerCell);
        });

        // Create specification rows
        comparisonData.specifications.forEach(spec => {
            const row = document.createElement('tr');
            row.className = 'spec-row';
            
            const specNameCell = document.createElement('td');
            specNameCell.className = 'spec-name';
            specNameCell.textContent = spec;
            row.appendChild(specNameCell);
            
            comparisonData.models.forEach(model => {
                const specValueCell = document.createElement('td');
                specValueCell.className = 'spec-value';
                
                if (model.specs[spec]) {
                    if (specsWithData.has(spec)) {
                        // Show actual data for specs
                        let value = '';
                        
                        // Get value from specValues object
                        if (model.specValues && model.specValues[spec]) {
                            value = model.specValues[spec];
                        } else {
                            // Try to get from basicInfo
                            const basicInfoKey = spec.toLowerCase().replace(/ /g, '_');
                            value = model.basicInfo[basicInfoKey] || '';
                        }
                        specValueCell.textContent = value || '';
                    } else {
                        // Show tick for specifications list
                        specValueCell.innerHTML = '<span class="tick">✓</span>';
                    }
                } else {
                    // Show cross for both data specs and specifications list
                    specValueCell.innerHTML = '<span class="cross">✗</span>';
                }
                
                row.appendChild(specValueCell);
            });
            
            comparisonBody.appendChild(row);
        });

        // Add score row to footer
        const scoreRow = document.querySelector('.score-row');
        scoreRow.innerHTML = '<td class="spec-name">Total Score</td>';
        
        comparisonData.models.forEach((model, index) => {
            const scoreCell = document.createElement('td');
            scoreCell.className = `score-cell ${index === winnerIndex ? 'winner' : ''}`;
            
            const actualScore = Math.min(model.score, comparisonData.totalSpecifications);
            scoreCell.textContent = `${actualScore}/${comparisonData.totalSpecifications}`;
            scoreRow.appendChild(scoreCell);
        });

        // Generate conclusion
        generateConclusion(comparisonData, conclusionContent);
        
        // Show results section
        resultsSection.style.display = 'block';
        
        // Scroll to results
        resultsSection.scrollIntoView({ behavior: 'smooth' });
    }

    // Generate conclusion
    function generateConclusion(comparisonData, container) {
        // Sort models by score in descending order
        const sortedModels = [...comparisonData.models].sort((a, b) => b.score - a.score);
        const winner = sortedModels[0];
        
        const winnerScore = Math.min(winner.score, comparisonData.totalSpecifications);
        const winnerPercentage = Math.round((winnerScore / comparisonData.totalSpecifications) * 100);
        
        // Create URL-friendly slugs for winner
        const winnerModelSlug = winner.name.toLowerCase()
            .replace(/ /g, '-')
            .replace(/[^a-z0-9-]/g, '')
            .replace(/-+/g, '-');
        const winnerBrandSlug = winner.brand.toLowerCase()
            .replace(/ /g, '-')
            .replace(/[^a-z0-9-]/g, '')
            .replace(/-+/g, '-');
        const winnerDetailsUrl = currentCountry ? 
            `/${currentCountry}/${winner.vehicle_type_name || 'car'}/brand/${winnerBrandSlug}/${winnerModelSlug}/` : 
            `/${winner.vehicle_type_name || 'car'}/brand/${winnerBrandSlug}/${winnerModelSlug}/`;
        
        let conclusionHTML = `
            <div class="winner-section">
                <div class="winner-title">
                    🏆 <a href="${winnerDetailsUrl}" 
                       style="text-decoration: none !important; color: #22c55e;" 
                       onmouseover="this.style.textDecoration='none'; this.style.color='#16a34a';" 
                       onmouseout="this.style.textDecoration='none'; this.style.color='#22c55e';"
                       title="View ${winner.brand} ${winner.name} details">
                        ${winner.brand} ${winner.name}
                    </a> - Winner
                </div>
                <p class="text-white">
                    Leads with <strong>${winnerPercentage}%</strong> of specifications met, scoring <strong>${winnerScore}</strong> out of <strong>${comparisonData.totalSpecifications}</strong> total specifications.
                    <br>
                    <a href="${winnerDetailsUrl}" class="view-details-btn inline-block mt-3" title="View full details of ${winner.brand} ${winner.name}">
                        <i class="fas fa-external-link-alt mr-2"></i>View Winner Details
                    </a>
                </p>
            </div>
        `;

        if (sortedModels.length > 1) {
            conclusionHTML += `
                <div class="mb-6">
                    <h4 class="text-lg font-semibold text-white mb-3">Ranking Summary</h4>
                    <ul class="ranking-list">`;
            
            sortedModels.forEach((model, index) => {
                const position = index === 0 ? '1st' : index === 1 ? '2nd' : index === 2 ? '3rd' : '4th';
                const modelScore = Math.min(model.score, comparisonData.totalSpecifications);
                const modelPercentage = Math.round((modelScore / comparisonData.totalSpecifications) * 100);
                const isWinner = index === 0;
                
                // Create URL for each model
                const modelSlug = model.name.toLowerCase()
                    .replace(/ /g, '-')
                    .replace(/[^a-z0-9-]/g, '')
                    .replace(/-+/g, '-');
                const brandSlug = model.brand.toLowerCase()
                    .replace(/ /g, '-')
                    .replace(/[^a-z0-9-]/g, '')
                    .replace(/-+/g, '-');
                const modelDetailsUrl = currentCountry ? 
                    `/${currentCountry}/${model.vehicle_type_name || 'car'}/brand/${brandSlug}/${modelSlug}/` : 
                    `/${model.vehicle_type_name || 'car'}/brand/${brandSlug}/${modelSlug}/`;
                
                conclusionHTML += `
                    <li class="ranking-item ${isWinner ? 'winner' : ''}">
                        <span class="ranking-position">${position} Place:</span> 
                        <a href="${modelDetailsUrl}" 
                           style="text-decoration: none !important; color: white;" 
                           onmouseover="this.style.textDecoration='none'; this.style.color='#dc2626';" 
                           onmouseout="this.style.textDecoration='none'; this.style.color='white';"
                           title="View ${model.brand} ${model.name} details">
                            ${model.brand} ${model.name}
                        </a>
                        <strong>(${modelPercentage}% - ${modelScore}/${comparisonData.totalSpecifications})</strong>
                        ${isWinner ? ' - 🏆 WINNER' : ''}
                    </li>`;
            });
            
            conclusionHTML += `</ul></div>`;
        }

        // Missing specifications for winner
        const missingSpecs = comparisonData.specifications.filter(spec => !winner.specs[spec]);
        if (missingSpecs.length > 0) {
            conclusionHTML += `
                <div class="mb-6">
                    <h4 class="text-lg font-semibold text-white mb-2">Considerations for ${winner.brand} ${winner.name}</h4>
                    <p class="text-white mb-3">The winner is missing these specifications you might want to consider:</p>
                    <div class="text-sm text-white bg-gray-800 rounded-lg p-4 border border-gray-600">
                        ${missingSpecs.slice(0, 6).join(', ')}${missingSpecs.length > 6 ? ` and ${missingSpecs.length - 6} more...` : ''}
                    </div>
                </div>
            `;
        }

        // Final recommendation
        conclusionHTML += `
            <div class="mt-6 p-4 bg-gray-800 rounded-lg border border-gray-600">
                <h4 class="text-lg font-semibold text-white mb-2">💡 Final Recommendation</h4>
                <p class="text-white">
                    Based on your comparison, the <strong class="text-green-400">${winner.brand} ${winner.name}</strong> offers the best overall specifications. 
                    ${missingSpecs.length > 0 ? 
                        'Consider if the missing features are important for your specific needs before making a final decision.' : 
                        'It provides comprehensive features across all categories and is our top recommendation.'
                    }
                </p>
                <div class="mt-4">
                    <a href="${winnerDetailsUrl}" class="view-details-btn" title="View full details of ${winner.brand} ${winner.name}">
                        <i class="fas fa-info-circle mr-2"></i>View Complete Details of ${winner.brand} ${winner.name}
                    </a>
                </div>
            </div>
        `;

        container.innerHTML = conclusionHTML;
    }

    // Share Modal Functions
    function openShareModal() {
        if (!currentComparisonData) {
            alert('Please perform a comparison first');
            return;
        }
        document.getElementById('shareModal').style.display = 'flex';
    }

    function closeShareModal() {
        document.getElementById('shareModal').style.display = 'none';
    }

    // Social Share Functions
    function shareOnTwitter() {
        if (!currentComparisonData) return;
        
        const modelNames = currentComparisonData.models.map(model => `${model.brand} ${model.name}`).join(' vs ');
        const url = encodeURIComponent(getShareUrl());
        const text = encodeURIComponent(`Check out this vehicle comparison: ${modelNames} on GadiDrive`);
        window.open(`https://twitter.com/intent/tweet?text=${text}&url=${url}`, '_blank');
        closeShareModal();
    }

    function shareOnFacebook() {
        if (!currentComparisonData) return;
        
        const url = encodeURIComponent(getShareUrl());
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${url}`, '_blank');
        closeShareModal();
    }

    function shareOnLinkedIn() {
        if (!currentComparisonData) return;
        
        const modelNames = currentComparisonData.models.map(model => `${model.brand} ${model.name}`).join(' vs ');
        const url = encodeURIComponent(getShareUrl());
        const title = encodeURIComponent(`Vehicle Comparison: ${modelNames}`);
        const summary = encodeURIComponent(`Compare vehicles side-by-side with detailed specifications on GadiDrive`);
        window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${url}`, '_blank');
        closeShareModal();
    }

    function shareOnWhatsApp() {
        if (!currentComparisonData) return;
        
        const modelNames = currentComparisonData.models.map(model => `${model.brand} ${model.name}`).join(' vs ');
        const url = encodeURIComponent(getShareUrl());
        const text = encodeURIComponent(`Check out this vehicle comparison: ${modelNames}\n${url}`);
        window.open(`https://wa.me/?text=${text}`, '_blank');
        closeShareModal();
    }

    function copyToClipboard() {
        const url = getShareUrl();
        navigator.clipboard.writeText(url).then(() => {
            const btn = event.currentTarget;
            const span = btn.querySelector('span');
            const originalText = span.textContent;
            span.textContent = 'Copied!';
            
            setTimeout(() => {
                span.textContent = originalText;
            }, 2000);
        }).catch(err => {
            console.error('Failed to copy: ', err);
            // Fallback
            const textArea = document.createElement('textarea');
            textArea.value = url;
            document.body.appendChild(textArea);
            textArea.select();
            document.execCommand('copy');
            document.body.removeChild(textArea);
            
            const btn = event.currentTarget;
            const span = btn.querySelector('span');
            const originalText = span.textContent;
            span.textContent = 'Copied!';
            
            setTimeout(() => {
                span.textContent = originalText;
            }, 2000);
        });
    }

    // Close modal when clicking outside
    window.onclick = function(event) {
        const shareModal = document.getElementById('shareModal');
        if (event.target === shareModal) {
            closeShareModal();
        }
    }

    // Keyboard support for modal
    document.addEventListener('keydown', function(e) {
        const shareModal = document.getElementById('shareModal');
        if (shareModal && shareModal.style.display === 'flex') {
            if (e.key === 'Escape') {
                closeShareModal();
            }
        }
    });
</script>
</body>
</html>
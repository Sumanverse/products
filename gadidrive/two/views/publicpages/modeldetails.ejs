                        margin-left: 5px;
                        text-decoration: underline;
                    }

                    .model-image {
                        width: 300px;
                        height: 200px;
                        border-radius: 12px;
                        object-fit: cover;
                        border: 2px solid #374151;
                        flex-shrink: 0;
                    }

                    .model-info {
                        flex: 1;
                    }

                    .model-brand {
                        font-size: 1.1rem;
                        color: var(--text-muted);
                        margin-bottom: 0.5rem;
                    }

                    .model-brand a {
                        color: var(--text-muted);
                        text-decoration: none;
                        transition: color 0.3s ease;
                    }

                    .model-brand a:hover {
                        color: var(--primary-red);
                    }

                    .model-name {
                        font-size: 2.5rem;
                        font-weight: 800;
                        color: white;
                        margin-bottom: 1rem;
                        background: linear-gradient(to right, #ffffff, #e5e5e5);
                        -webkit-background-clip: text;
                        -webkit-text-fill-color: transparent;
                    }

                    .model-meta {
                        display: flex;
                        align-items: center;
                        gap: 2rem;
                        flex-wrap: wrap;
                    }

                    .safety-rating {
                        display: inline-flex;

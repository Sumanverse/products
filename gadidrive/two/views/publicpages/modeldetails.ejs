                                                                                                                    const countryPath = (typeof country !== 'undefined' && country) ? `/${country.country_name.toLowerCase()}` : '';
                                                                                                                    const bLink = `${countryPath}/${vehicletypename}/${brandSlug}/`;
                                                                                                                    %>

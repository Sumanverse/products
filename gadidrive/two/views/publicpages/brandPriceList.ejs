<%- include('../partials/head.ejs', {
    title: seoTitle,
    description: seoDescription,
    path: path,
    image: ogImage
}) %>

<% 
    const countryPrefixBreadBPL = country ? '/' + country.country_name.toLowerCase() : '';
    const vtSlugBreadBPL = vehicleType.vehicle_type_name.toLowerCase();
    const brandSlugBreadBPL = brand.name.toLowerCase().replace(/ /g, '-').replace(/[^\w-]/g, '');
    
    const breadcrumbs = [
        { name: vehicleType.vehicle_type_name + 's', url: `${countryPrefixBreadBPL}/${vtSlugBreadBPL}` },
        { name: 'Price List', url: `${countryPrefixBreadBPL}/${vtSlugBreadBPL}/price-list` },
        { name: brand.name, url: `${countryPrefixBreadBPL}/${vtSlugBreadBPL}/${brandSlugBreadBPL}/price-list` }
    ];
%>

<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Poppins', sans-serif; background: #000; color: #fff; min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; }
main { flex: 1; padding: 15px 20px 40px; }
.container { max-width: 1400px; margin: 0 auto; }

/* Modern Vehicle Type Navbar (Matched with Brands Page) */
.vehicle-nav-wrapper {
    display: flex;
    justify-content: center;
    width: 100%;
    margin: 2rem 0 1rem 0;
}

.vehicle-nav {
    background: rgba(17, 17, 17, 0.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(220, 38, 38, 0.1);
    border-radius: 60px;
    padding: 0.4rem;
    display: inline-flex;
    max-width: 100%;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
}

.vehicle-nav-container {
    display: flex;
    gap: 0.25rem;
    overflow-x: auto;
    padding: 0.2rem;
    scrollbar-width: thin;
    scrollbar-color: #DC2626 #2a2a2a;
    border-radius: 60px;
}

.vehicle-nav-container::-webkit-scrollbar {
    height: 3px;
}

.vehicle-nav-container::-webkit-scrollbar-track {
    background: #2a2a2a;
    border-radius: 10px;
}

.vehicle-nav-container::-webkit-scrollbar-thumb {
    background: #DC2626;
    border-radius: 10px;
}

.vehicle-nav-item {
    flex: 0 0 auto;
    padding: 0.7rem 2rem;
    background: transparent;
    border: none;
    border-radius: 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: #d1d5db;
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.3px;
    position: relative;
    white-space: nowrap;
    text-transform: capitalize;
}

.vehicle-nav-item:hover {
    color: #ffffff;
    background: rgba(220, 38, 38, 0.08);
}

.vehicle-nav-item.active {
    background: #DC2626;
    color: white;
    font-weight: 600;
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
}

/* Brand Hero */
.brand-hero { display: flex; align-items: center; gap: 28px; margin-bottom: 28px; padding: 28px; background: linear-gradient(135deg, #111 0%, #0d0d0d 100%); border: 1px solid #222; border-radius: 24px; flex-wrap: wrap; position: relative; overflow: hidden; }
.brand-hero::before { content: ''; position: absolute; top: -40%; right: -10%; width: 250px; height: 250px; background: radial-gradient(circle, rgba(220,38,38,.12) 0%, transparent 70%); pointer-events: none; }
.brand-hero-logo { width: 110px; height: 110px; background: #1a1a1a; border: 1px solid #333; border-radius: 20px; padding: 16px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(0,0,0,.5); }
.brand-hero-logo img { max-width: 100%; max-height: 100%; object-fit: contain; }
.brand-hero-text h1 { font-size: 2rem; font-weight: 800; color: white; line-height: 1.2; letter-spacing: -.5px; }
.brand-hero-text h1 span { color: #DC2626; }
.brand-hero-stats { display: flex; gap: 16px; margin-top: 12px; flex-wrap: wrap; }
.stat-chip { background: rgba(255,255,255,.05); border: 1px solid #2a2a2a; border-radius: 10px; padding: 8px 16px; }
.stat-chip .s-label { font-size: .75rem; color: #6B7280; }
.stat-chip .s-value { font-size: 1.1rem; font-weight: 700; color: #DC2626; }

/* Description */
.description-container { cursor: pointer; border-radius: 12px; padding: 18px; background: #111; border: 1px solid #222; margin-bottom: 24px; transition: all .3s; }
.description-container:hover { border-color: #DC2626; }
.description-text { font-size: 1rem; line-height: 1.7; color: #9CA3AF; overflow: hidden; }
.description-text.collapsed { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; max-height: 3.4em; }
.description-text.expanded { max-height: 500px; }

/* 2-Column Layout */
.page-layout { display: flex; gap: 2rem; align-items: flex-start; }
.main-content { flex: 1; min-width: 0; }
.sidebar { 
    width: 300px; 
    flex-shrink: 0; 
    position: sticky; 
    top: 90px; 
    max-height: calc(100vh - 110px); 
    overflow-y: auto; 
    padding-right: 8px;
    scrollbar-width: thin;
    scrollbar-color: rgba(220,38,38,.3) transparent;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-thumb { background: rgba(220,38,38,0.3); border-radius: 10px; }

/* Main Content Box */
.main-content-box { background: #111; border: 1px solid #222; border-radius: 24px; padding: 32px; }

/* Model Container */
.model-container { margin-bottom: 2rem; }
.model-container:last-child { margin-bottom: 0; }

/* Model Header with image */
.model-header { display: flex; align-items: center; gap: 16px; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 16px; padding: 1rem 1.5rem; transition: all .3s; margin-bottom: .6rem; }
.model-header:hover { background: #222; border-color: #DC2626; transform: translateX(4px); }
.model-header-thumb { width: 90px; height: 65px; background: #111; border-radius: 10px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.model-header-thumb img { width: 100%; height: 100%; object-fit: contain; }
.model-thumb-placeholder { font-size: 1.8rem; font-weight: 900; color: rgba(255,255,255,.06); }
.model-title { flex: 1; min-width: 0; }
.model-title h3 { font-size: 1.3rem; font-weight: 700; color: white; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.model-actions { display: flex; align-items: center; gap: 16px; flex-shrink: 0; }
.model-price { font-size: 1.5rem; font-weight: 700; color: #DC2626; white-space: nowrap; }
.model-details-btn { padding: .55rem 1.4rem; background: #DC2626; border-radius: 50px; color: white; font-weight: 600; text-decoration: none; transition: all .3s; font-size: .88rem; display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; }
.model-details-btn:hover { background: white; color: #DC2626; transform: translateY(-2px); box-shadow: 0 6px 16px rgba(220,38,38,.3); }

/* Variants */
.variants-container { margin-left: 1.2rem; display: flex; flex-direction: column; gap: .4rem; margin-bottom: .5rem; }
.variant-item { display: flex; justify-content: space-between; align-items: center; background: #141414; border: 1px solid #2a2a2a; border-radius: 10px; padding: .65rem 1.2rem; transition: all .3s; }
.variant-item:hover { background: #1e1e1e; border-color: rgba(220,38,38,.4); transform: translateX(4px); }
.variant-info h4 { font-size: 1rem; font-weight: 600; color: #e5e7eb; }
.variant-actions { display: flex; align-items: center; gap: 14px; }
.variant-price { font-size: 1.1rem; font-weight: 700; color: #DC2626; }
.variant-details-btn { padding: .35rem 1.1rem; background: transparent; border: 1px solid #DC2626; border-radius: 50px; color: #DC2626; font-size: .82rem; font-weight: 500; text-decoration: none; transition: all .3s; white-space: nowrap; }
.variant-details-btn:hover { background: #DC2626; color: white; }

/* No models */
.no-models { text-align: center; padding: 60px 20px; background: #111; border-radius: 20px; border: 1px solid #333; }
.no-models i { font-size: 3rem; color: #DC2626; margin-bottom: 20px; display: block; }
.no-models p { font-size: 1.2rem; color: #9CA3AF; }

/* ===== PREMIUM SIDEBAR ===== */
.sidebar-box { background: rgba(14,14,14,.95); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,.06); border-radius: 20px; padding: 22px; margin-bottom: 18px; position: relative; overflow: hidden; }
.sidebar-box::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(220,38,38,.5), transparent); }

.sidebar-title { font-size: .78rem; font-weight: 800; color: white; text-transform: uppercase; letter-spacing: .18em; margin-bottom: 6px; display: flex; align-items: center; gap: 10px; }
.sidebar-dot { width: 8px; height: 8px; background: #DC2626; border-radius: 50%; flex-shrink: 0; box-shadow: 0 0 10px rgba(220,38,38,.8); animation: sdot 2s infinite; }
@keyframes sdot { 0%,100%{box-shadow:0 0 8px rgba(220,38,38,.7)} 50%{box-shadow:0 0 18px rgba(220,38,38,1)} }
.sidebar-subtitle { font-size: .72rem; color: #4B5563; margin-bottom: 16px; font-style: italic; }

/* Premium Sidebar Brand Card */
.sidebar-brand-card { 
    display: flex; 
    align-items: center; 
    gap: 14px; 
    padding: 12px 14px; 
    border-radius: 16px; 
    text-decoration: none; 
    color: white; 
    transition: all .35s cubic-bezier(0.4, 0, 0.2, 1); 
    border: 1px solid rgba(255,255,255,.05); 
    margin-bottom: 8px; 
    position: relative; 
    overflow: hidden; 
    background: rgba(255,255,255,.03); 
}
.sidebar-brand-card::after { 
    content: ''; 
    position: absolute; 
    left: 0; 
    top: 0; 
    bottom: 0; 
    width: 4px; 
    background: #DC2626; 
    transform: scaleY(0); 
    transition: transform .3s; 
    border-radius: 0 4px 4px 0; 
}
.sidebar-brand-card:hover { 
    border-color: rgba(220,38,38,.4); 
    background: linear-gradient(90deg, rgba(220,38,38,.1) 0%, rgba(220,38,38,0.02) 100%); 
    transform: translateX(8px); 
    box-shadow: 0 8px 25px rgba(0,0,0,.4); 
}
.sidebar-brand-card:hover::after { transform: scaleY(1); }
.sidebar-brand-logo { 
    width: 50px; 
    height: 50px; 
    background: #151515; 
    border: 1px solid rgba(255,255,255,.08); 
    border-radius: 14px; 
    padding: 8px; 
    flex-shrink: 0; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    transition: all .3s; 
}
.sidebar-brand-card:hover .sidebar-brand-logo { 
    border-color: #DC2626; 
    transform: scale(1.05); 
}
.sidebar-brand-logo img { max-width: 100%; max-height: 100%; object-fit: contain; }
.sidebar-brand-info { flex: 1; min-width: 0; }
.sidebar-brand-name { 
    font-size: .95rem; 
    font-weight: 700; 
    color: white; 
    white-space: nowrap; 
    overflow: hidden; 
    text-overflow: ellipsis; 
    transition: color .3s; 
}
.sidebar-brand-card:hover .sidebar-brand-name { color: #DC2626; }
.sidebar-brand-meta { display: flex; align-items: center; gap: 8px; margin-top: 4px; }
.sidebar-brand-count { font-size: .7rem; color: #6B7280; background: rgba(255,255,255,.04); padding: 2px 7px; border-radius: 20px; border: 1px solid rgba(255,255,255,.06); }
.sidebar-brand-cta { font-size: .68rem; color: #DC2626; font-weight: 700; white-space: nowrap; opacity: 0; transition: opacity .3s; letter-spacing: .03em; }
.sidebar-brand-card:hover .sidebar-brand-cta { opacity: 1; }
.sidebar-brand-arrow { color: #DC2626; font-size: .8rem; flex-shrink: 0; margin-left: auto; }

/* Schema hidden */
.schema-hidden { display: none; }

/* Responsive */
@media (max-width: 1024px) { .page-layout { flex-direction: column; } .sidebar { width: 100%; position: static; } }
@media (max-width: 768px) {
    .brand-hero { gap: 18px; padding: 20px; }
    .brand-hero-logo { width: 80px; height: 80px; }
    .brand-hero-text h1 { font-size: 1.5rem; }
    .main-content-box { padding: 20px; }
    .model-header { flex-wrap: wrap; gap: 10px; }
    .model-actions { width: 100%; justify-content: flex-end; }
    .model-header-thumb { width: 70px; height: 52px; }
}
@media (max-width: 480px) {
    .variant-item { flex-direction: column; align-items: flex-start; gap: 8px; padding: 12px; }
    .variant-actions { width: 100%; justify-content: flex-end; }
    .model-details-btn { width: 100%; justify-content: center; }
    .model-actions { flex-direction: column; align-items: flex-start; width: 100%; }
    .model-header { gap: 12px; padding: 12px; align-items: center; }
    .model-header-thumb { width: 80px; height: 60px; display: flex !important; }
    .model-header-thumb img { display: block !important; }
}
</style>
</head>

<body>
<%- include('../partials/navbar', {
    currentPage: 'priceList',
    country: country,
    allVehicleTypes: (typeof vehicleTypes !== 'undefined' ? vehicleTypes : (typeof allVehicleTypes !== 'undefined' ? allVehicleTypes : []))
}) %>

<main>
    <div class="container">
        <%- include('../partials/breadcrumb', { breadcrumbs, countryPrefix: countryPrefixBreadBPL }) %>
        
        <!-- Brand Hero -->
        <div class="brand-hero">
            <div class="brand-hero-logo">
                <% if (brand.image_path) { %>
                    <img src="<%= brand.image_path %>" alt="<%= brand.name %> Logo" onerror="this.style.display='none'">
                <% } else { %>
                    <span style="font-size:2.5rem;font-weight:900;color:rgba(255,255,255,.08);"><%= (brand.name||'?').charAt(0) %></span>
                <% } %>
            </div>
            <div class="brand-hero-text">
                <h1>All <span><%= brand.name %></span> <%= vehicleType.vehicle_type_name %> Prices<% if (country) { %> in <span><%= country.country_name %></span><% } %></h1>
                <div class="brand-hero-stats">
                    <div class="stat-chip"><div class="s-label">Models</div><div class="s-value"><%= totalModels %></div></div>
                    <div class="stat-chip"><div class="s-label">Variants</div><div class="s-value"><%= totalVariants %></div></div>
                    <div class="stat-chip"><div class="s-label">Price Range</div><div class="s-value" style="font-size:.9rem;"><%= priceRange %></div></div>
                </div>
            </div>
        </div>

        <!-- Description -->
        <div class="description-container" onclick="toggleDescription()">
            <div class="description-text collapsed" id="descriptionText">
                <%= seoDescription %>
            </div>
        </div>

        <!-- 2-Column Layout -->
        <div class="page-layout">
            <!-- Main Content -->
            <div class="main-content">
                <div class="main-content-box">
                    <% if (models && models.length > 0) { %>
                        <% models.forEach(model => { %>
                        <div class="model-container">
                            <!-- Model Header with Image -->
                            <div class="model-header">
                                <div class="model-header-thumb">
                                    <% if (model.model_image) { %>
                                        <img src="<%= model.model_image %>" alt="<%= model.model_name %>" onerror="this.parentElement.innerHTML='<span class=model-thumb-placeholder><%= model.model_name.charAt(0) %></span>'">
                                    <% } else { %>
                                        <span class="model-thumb-placeholder"><%= model.model_name.charAt(0) %></span>
                                    <% } %>
                                </div>
                                <div class="model-title">
                                    <h3><%= model.model_name %></h3>
                                </div>
                                <div class="model-actions">
                                    <% if (model.starting_price) { %>
                                        <span class="model-price"><%= currencySymbol %> <%= new Intl.NumberFormat('en-IN').format(model.starting_price) %></span>
                                    <% } %>
                                    <a href="/<%= regionSlug %>/<%= vehicleType.vehicle_type_name %>/<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>/<%= model.model_name.toLowerCase().replace(/\s+/g, '-') %>/" class="model-details-btn">
                                        Details <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>

                            <!-- Variants (no image) -->
                            <div class="variants-container">
                                <% if (model.variants && model.variants.length > 0) { %>
                                    <% model.variants.forEach(variant => { %>
                                    <div class="variant-item">
                                        <div class="variant-info"><h4><%= variant.variant_name %></h4></div>
                                        <div class="variant-actions">
                                            <% if (variant.variant_price) { %>
                                                <span class="variant-price"><%= currencySymbol %> <%= new Intl.NumberFormat('en-IN').format(variant.variant_price) %></span>
                                            <% } %>
                                            <a href="/<%= regionSlug %>/<%= vehicleType.vehicle_type_name %>/<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>/<%= model.model_name.toLowerCase().replace(/\s+/g, '-') %>/<%= variant.variant_name.toLowerCase().replace(/\s+/g, '-') %>/" class="variant-details-btn">
                                                Details <i class="fas fa-arrow-right"></i>
                                            </a>
                                        </div>
                                    </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="variant-item">
                                        <div class="variant-info"><h4><%= model.model_name %></h4></div>
                                        <div class="variant-actions">
                                            <% if (model.starting_price) { %>
                                                <span class="variant-price"><%= currencySymbol %> <%= new Intl.NumberFormat('en-IN').format(model.starting_price) %></span>
                                            <% } %>
                                            <a href="/<%= regionSlug %>/<%= vehicleType.vehicle_type_name %>/<%= brand.name.toLowerCase().replace(/\s+/g, '-') %>/<%= model.model_name.toLowerCase().replace(/\s+/g, '-') %>/" class="variant-details-btn">
                                                Details <i class="fas fa-arrow-right"></i>
                                            </a>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        <% }) %>
                    <% } else { %>
                        <div class="no-models">
                            <i class="fas fa-car"></i>
                            <p>No models found for <%= brand.name %> in <%= countryName %>.</p>
                        </div>
                    <% } %>
                </div>
            </div><!-- end main-content -->

            <!-- PREMIUM SIDEBAR -->
            <aside class="sidebar">
                <% if (typeof recommendedBrands !== 'undefined' && recommendedBrands && recommendedBrands.length > 0) { %>
                <div class="sidebar-box">
                    <div class="sidebar-title"><span class="sidebar-dot"></span> Similar Brands</div>
                    <div class="sidebar-subtitle">Other popular <%= vehicleType.vehicle_type_name %> brands</div>
                    <% recommendedBrands.forEach(b => {
                        const bName2 = b.brand_name || b.name || '';
                        const bImg = b.image_path || b.brand_image || '';
                        const bSlug = bName2.toLowerCase().replace(/ /g, '-');
                        const bCount = b.model_count || 0;
                        const bUrl = (regionSlug ? '/' + regionSlug : '') + '/' + vehicleType.vehicle_type_name + '/' + bSlug + '/price-list/';
                    %>
                        <a href="<%= bUrl %>" class="sidebar-brand-card">
                            <div class="sidebar-brand-logo">
                                <% if (bImg) { %>
                                    <img src="<%= bImg %>" alt="<%= bName2 %>" onerror="this.style.display='none'">
                                <% } else { %>
                                    <span style="font-size:1.1rem;font-weight:900;color:rgba(255,255,255,.15);"><%= bName2.charAt(0) %></span>
                                <% } %>
                            </div>
                            <div class="sidebar-brand-info">
                                <div class="sidebar-brand-name"><%= bName2 %></div>
                                <div class="sidebar-brand-meta">
                                    <span class="sidebar-brand-count"><%= bCount %> models</span>
                                    <% if (b.min_price) { %>
                                        <span style="font-size: .7rem; color: #DC2626; font-weight: 600;">From <%= currencySymbol %> <%= (parseFloat(b.min_price) || 0).toLocaleString() %></span>
                                    <% } %>
                                </div>
                                <div class="sidebar-brand-meta" style="margin-top: 2px;">
                                    <span class="sidebar-brand-cta">View Prices →</span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
                <% } %>

                <!-- Similar Price Models Section -->
                <% if (typeof similarPriceModels !== 'undefined' && similarPriceModels && similarPriceModels.length > 0) { %>
                <div class="sidebar-box">
                    <div class="sidebar-title"><span class="sidebar-dot"></span> Suggested Models</div>
                    <% similarPriceModels.forEach(m => { 
                        const mName = m.model_name || '';
                        const bName = m.brand_name || '';
                        const bSlug = bName.toLowerCase().replace(/ /g, '-');
                        const mSlug = mName.toLowerCase().replace(/ /g, '-');
                        const countryPath = regionSlug ? `/${regionSlug}` : '';
                        const mUrl = `${countryPath}/${vehicleType.vehicle_type_name}/${bSlug}/${mSlug}/`;
                    %>
                        <a href="<%= mUrl %>" class="sidebar-brand-card">
                            <div class="sidebar-brand-logo" style="background: #111; padding: 4px; border-radius: 8px;">
                                <% if (m.model_image) { %>
                                    <img src="<%= m.model_image %>" alt="<%= mName %>" style="object-fit: cover; border-radius: 6px;">
                                <% } else { %>
                                    <i class="fas fa-car" style="color:rgba(255,255,255,.1);"></i>
                                <% } %>
                            </div>
                            <div class="sidebar-brand-info">
                                <div class="sidebar-brand-name"><%= bName %> <%= mName %></div>
                                <div class="sidebar-brand-meta">
                                    <span style="font-size: .75rem; color: #DC2626; font-weight: 700;">
                                        <%= currencySymbol %> <%= (parseFloat(m.starting_price) || 0).toLocaleString() %>
                                    </span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
                <% } %>

                <!-- Browse by Type -->
                <div class="sidebar-box">
                    <div class="sidebar-title"><span class="sidebar-dot"></span> Browse by Type</div>
                    <% 
                        let sidebarTypes = (typeof vehicleTypes !== 'undefined' ? vehicleTypes : (typeof allVehicleTypes !== 'undefined' ? allVehicleTypes : []));
                        
                        // Ensure current vehicleType is in the sidebar list too
                        if (vehicleType && !sidebarTypes.find(vt => vt.vehicle_type_id == vehicleType.vehicle_type_id)) {
                            sidebarTypes = [vehicleType, ...sidebarTypes];
                        }

                        if (sidebarTypes && sidebarTypes.length > 0) { 
                            sidebarTypes.forEach(vt => {
                        const isActive = vehicleType && vehicleType.vehicle_type_id == vt.vehicle_type_id;
                        const vtUrl = (regionSlug ? '/' + regionSlug : '') + '/' + vt.vehicle_type_name + '/price-list/';
                    %>
                        <a href="<%= vtUrl %>" class="sidebar-brand-card" style="<%= isActive ? 'border-color:rgba(220,38,38,.4);background:rgba(220,38,38,.07);' : '' %>">
                            <div class="sidebar-brand-info">
                                <div class="sidebar-brand-name" style="<%= isActive ? 'color:#DC2626;' : '' %>"><%= vt.vehicle_type_name %></div>
                                <div class="sidebar-brand-meta">
                                    <span class="sidebar-brand-count">Price List</span>
                                    <% if (isActive) { %><span style="font-size:.68rem;color:#DC2626;font-weight:700;">Current ✓</span><% } %>
                                </div>
                            </div>
                            <i class="fas fa-chevron-right" style="color:#DC2626;font-size:.75rem;flex-shrink:0;"></i>
                        </a>
                    <% }) } %>
                </div>

                <!-- Brand Stats Box -->
                <div class="sidebar-box">
                    <div class="sidebar-title"><span class="sidebar-dot"></span> Brand Info</div>
                    <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px;background:rgba(255,255,255,.03);padding:12px;border-radius:14px;border:1px solid rgba(255,255,255,.05);">
                        <div class="sidebar-brand-logo" style="width:52px;height:52px;">
                            <% if (brand.image_path) { %>
                                <img src="<%= brand.image_path %>" alt="<%= brand.name %>" onerror="this.style.display='none'">
                            <% } else { %>
                                <span style="font-size:1.2rem;font-weight:900;color:rgba(255,255,255,.1);"><%= (brand.name||'?').charAt(0) %></span>
                            <% } %>
                        </div>
                        <div>
                            <div style="font-size:1.05rem;font-weight:800;color:white;"><%= brand.name %></div>
                            <div style="font-size:.78rem;color:#6B7280;text-transform:uppercase;letter-spacing:.05em;"><%= vehicleType.vehicle_type_name %> Brand</div>
                        </div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                        <div style="background:rgba(220,38,38,.05);border:1px solid rgba(220,38,38,.2);border-radius:12px;padding:12px;text-align:center;">
                            <div style="font-size:.72rem;color:#6B7280;margin-bottom:2px;">Models</div>
                            <div style="font-size:1.3rem;font-weight:800;color:#DC2626;"><%= totalModels %></div>
                        </div>
                        <div style="background:rgba(220,38,38,.05);border:1px solid rgba(220,38,38,.2);border-radius:12px;padding:12px;text-align:center;">
                            <div style="font-size:.72rem;color:#6B7280;margin-bottom:2px;">Variants</div>
                            <div style="font-size:1.3rem;font-weight:800;color:#DC2626;"><%= totalVariants %></div>
                        </div>
                    </div>
                </div>
            </aside>

        </div><!-- end page-layout -->
    </div>
</main>

<%- include('../partials/footer', {
    country: country,
    allCountries: allCountries,
    allVehicleTypes: (typeof vehicleTypes !== 'undefined' ? vehicleTypes : (typeof allVehicleTypes !== 'undefined' ? allVehicleTypes : []))
}) %>

<div class="schema-hidden">
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": "<%= seoTitle %>",
        "description": "<%= seoDescription %>",
        "numberOfItems": <%= totalVariants %>,
        "url": "https://gadidrive.com<%= canonicalUrl %>",
        "brand": { "@type": "Brand", "name": "<%= brand.name %>" }
    }
    </script>
</div>

<script>
function toggleDescription() {
    const d = document.getElementById('descriptionText');
    d.classList.toggle('collapsed');
    d.classList.toggle('expanded');
}
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('img').forEach(img => {
        img.onerror = function() { this.onerror = null; this.style.display = 'none'; };
    });
});
</script>
</body>
</html>
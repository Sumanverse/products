                        <script>
                            document.addEventListener('DOMContentLoaded', () => {
                                // Smoke animation for empty state
                                const wheel = document.getElementById('wheel');
                                const smoke = document.getElementById('smoke');

                                if (wheel && smoke) {
                                    wheel.addEventListener('mouseenter', () => smoke.classList.add('active'));
                                    wheel.addEventListener('mouseleave', () => smoke.classList.remove('active'));
                                }

                                // Force image reload by adding timestamp to src
                                const brandLogo = document.querySelector('.brand-logo img');
                                if (brandLogo) {
                                    const currentSrc = brandLogo.src;
                                    if (!currentSrc.includes('t=')) {
                                        brandLogo.src = currentSrc + (currentSrc.includes('?') ? '&' : '?') + 't=' + Date.now();
                                    }
                                }
                            });
                        </script>
            </body>

            </html>